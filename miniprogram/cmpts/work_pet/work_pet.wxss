.pet-area {
	position: fixed;
	left: 0;
	top: 0;
	width: 100vw;
	height: 100vh;
	z-index: 9999;
	pointer-events: none;
}

.pet-movable {
	width: 164rpx;
	height: 178rpx;
	overflow: visible;
	pointer-events: auto;
}

.cat-stage {
	position: absolute;
	right: 0;
	bottom: 0;
	width: 160rpx;
	height: 174rpx;
	transform-origin: 50% 74%;
	animation: cat-idle 3.4s ease-in-out infinite;
}

.pet-img {
	position: absolute;
	left: 0;
	top: 2rpx;
	width: 160rpx;
	height: 160rpx;
	z-index: 3;
	transition: transform .16s ease, filter .16s ease;
	filter: drop-shadow(0 10rpx 10rpx rgba(17, 24, 39, .16));
}

.cat-shadow {
	position: absolute;
	left: 38rpx;
	bottom: 18rpx;
	width: 86rpx;
	height: 10rpx;
	border-radius: 50%;
	background: rgba(15, 23, 42, .2);
	filter: blur(2rpx);
	z-index: 1;
	transition: transform .16s ease, opacity .16s ease;
}

.cat-scruff {
	position: absolute;
	left: 62rpx;
	top: -4rpx;
	width: 34rpx;
	height: 22rpx;
	border-radius: 50%;
	background: rgba(255, 255, 255, .94);
	border: 3rpx solid rgba(55, 49, 45, .82);
	box-shadow: 0 5rpx 9rpx rgba(15, 23, 42, .12);
	opacity: 0;
	transform: translateY(10rpx) scale(.7);
	transition: opacity .14s ease, transform .14s ease;
	z-index: 5;
}

.pet-bubble {
	position: absolute;
	right: 4rpx;
	bottom: 172rpx;
	max-width: 220rpx;
	padding: 11rpx 15rpx;
	border-radius: 18rpx 18rpx 6rpx 18rpx;
	background: rgba(17, 24, 39, .9);
	color: #fff;
	box-shadow: 0 14rpx 30rpx rgba(17, 24, 39, .16);
	animation: bubble-in .18s ease-out both;
	z-index: 10;
}

.bubble-title {
	font-size: 20rpx;
	font-weight: 900;
	line-height: 1.35;
}

.bubble-meta {
	margin-top: 4rpx;
	font-size: 17rpx;
	color: rgba(255, 255, 255, .72);
	line-height: 1.3;
}

.pet-spark {
	position: absolute;
	width: 10rpx;
	height: 10rpx;
	border-radius: 50%;
	background: #ff2d62;
	opacity: 0;
	z-index: 8;
}

.pet-spark.one {
	right: 28rpx;
	top: 30rpx;
}

.pet-spark.two {
	left: 22rpx;
	top: 104rpx;
	background: #60a5fa;
}

.burst .pet-spark {
	animation: spark .42s ease-out both;
}

.dragging .cat-stage {
	animation: none;
}

.dragging .pet-img {
	transform: translateY(-22rpx) rotate(-6deg) scale(1.05);
	filter: drop-shadow(0 22rpx 18rpx rgba(17, 24, 39, .2));
}

.dragging .cat-scruff {
	opacity: 1;
	transform: translateY(0) scale(1);
}

.dragging .cat-shadow {
	opacity: .12;
	transform: translateY(22rpx) scale(.7);
}

@keyframes cat-idle {
	0%, 100% {
		transform: translateY(0) rotate(-1deg);
	}
	50% {
		transform: translateY(-3rpx) rotate(1deg);
	}
}

@keyframes bubble-in {
	from {
		opacity: 0;
		transform: translateY(10rpx) scale(.96);
	}
	to {
		opacity: 1;
		transform: translateY(0) scale(1);
	}
}

@keyframes spark {
	from {
		opacity: 1;
		transform: translateY(0) scale(1);
	}
	to {
		opacity: 0;
		transform: translateY(-32rpx) scale(1.7);
	}
}

.pet-chat-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	z-index: 10000;
	background: rgba(15, 23, 42, .28);
	display: flex;
	align-items: flex-end;
	justify-content: center;
	padding: 0 22rpx 36rpx;
	box-sizing: border-box;
}

.pet-chat-mask.is-fullscreen {
	align-items: stretch;
	padding: 0;
	background: rgba(42, 38, 34, .22);
}

.pet-chat-panel {
	width: 100%;
	height: 72vh;
	max-height: 72vh;
	background: #fff;
	border-radius: 20rpx 20rpx 16rpx 16rpx;
	box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, .22);
	overflow: hidden;
	animation: chat-in .16s ease-out both;
	display: flex;
	flex-direction: column;
}

.pet-chat-panel.is-fullscreen {
	height: 100vh;
	max-height: none;
	border-radius: 0;
	display: flex;
	flex-direction: column;
}

.pet-chat-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 16rpx 18rpx 14rpx;
	border-bottom: 1rpx solid #f0f2f5;
	gap: 10rpx;
	box-sizing: border-box;
	flex: none;
}

.pet-chat-panel.is-fullscreen .pet-chat-head {
	min-height: 84rpx;
	background: rgba(251, 247, 238, .96);
}

.pet-title-wrap {
	min-width: 0;
	flex: 1;
}

.pet-chat-title {
	font-size: 30rpx;
	font-weight: 900;
	color: #111827;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.pet-chat-panel.is-fullscreen .pet-chat-title {
	font-size: 28rpx;
}

.pet-chat-actions {
	display: flex;
	gap: 8rpx;
	font-size: 24rpx;
	color: #ff2d62;
	white-space: nowrap;
	flex: none;
}

.chat-icon-btn {
	width: 52rpx;
	height: 52rpx;
	line-height: 52rpx;
	text-align: center;
	border-radius: 50%;
	background: rgba(255, 255, 255, .62);
	border: 1rpx solid rgba(216, 207, 190, .75);
	color: #2a2622;
	font-size: 29rpx;
	font-weight: 800;
	box-sizing: border-box;
}

.context-pill {
	display: flex;
	align-items: center;
	gap: 8rpx;
	padding: 6rpx 10rpx;
	border-radius: 999rpx;
	background: rgba(255, 255, 255, .56);
	border: 1rpx solid rgba(216, 207, 190, .72);
	flex: none;
}

.context-ring {
	width: 58rpx;
	height: 58rpx;
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
}

.context-inner {
	width: 44rpx;
	height: 44rpx;
	line-height: 44rpx;
	text-align: center;
	border-radius: 50%;
	background: #fbf7ee;
	color: #3f6179;
	font-size: 17rpx;
	font-weight: 800;
}

.context-text {
	font-size: 20rpx;
	color: #6b6158;
	max-width: 160rpx;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.pet-chat-panel.is-fullscreen .context-text {
	display: none;
}

.pet-chat-body {
	display: flex;
	flex: 1;
	height: 0;
	min-height: 0;
	position: relative;
	overflow: hidden;
}

.pet-chat-panel.is-fullscreen .pet-chat-body {
	flex: 1;
	height: 0;
}

.chat-main {
	flex: 1;
	min-width: 0;
	min-height: 0;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

.chat-sidebar-scrim {
	position: absolute;
	left: 610rpx;
	right: 0;
	top: 0;
	bottom: 0;
	z-index: 2;
	background: rgba(42, 38, 34, .12);
}

.chat-sidebar {
	position: absolute;
	left: 0;
	top: 0;
	bottom: 0;
	z-index: 3;
	width: 610rpx;
	padding: 26rpx 22rpx 0;
	box-sizing: border-box;
	border-right: 1rpx solid rgba(216, 207, 190, .78);
	background: rgba(255, 255, 255, .96);
	box-shadow: 18rpx 0 46rpx rgba(42, 38, 34, .16);
}

.chat-sidebar::after {
	content: "";
