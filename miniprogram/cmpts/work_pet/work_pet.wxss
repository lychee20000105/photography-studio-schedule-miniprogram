	right: -140rpx;
	top: 0;
	bottom: 0;
	width: 140rpx;
	background: linear-gradient(90deg, rgba(42, 38, 34, .22), rgba(42, 38, 34, 0));
	pointer-events: none;
}

.sidebar-search-row {
	display: flex;
	align-items: center;
	gap: 18rpx;
	margin-bottom: 22rpx;
}

.sidebar-search {
