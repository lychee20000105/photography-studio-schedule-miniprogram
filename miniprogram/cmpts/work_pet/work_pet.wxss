	font-weight: 900;
}

.sidebar-avatar.small {
	width: 62rpx;
	height: 62rpx;
	line-height: 62rpx;
	font-size: 24rpx;
	background: #e5f3ff;
}

.sidebar-name {
	font-size: 30rpx;
	font-weight: 900;
	color: #111827;
}

.sidebar-sub {
	margin-top: 5rpx;
	font-size: 22rpx;
	color: #8b9099;
}

.sidebar-menu {
	padding: 2rpx 0 16rpx;
}

.sidebar-menu-item {
	display: flex;
	align-items: center;
	gap: 22rpx;
	height: 86rpx;
	font-size: 30rpx;
	font-weight: 800;
	color: #111827;
}

.sidebar-menu-icon {
	width: 44rpx;
	text-align: center;
	font-size: 34rpx;
	color: #111827;
}

.sidebar-divider {
	height: 1rpx;
	background: #ececec;
	margin: 4rpx 0 18rpx;
}

.new-chat-btn {
	width: 100%;
	height: 64rpx;
	line-height: 64rpx;
	border-radius: 12rpx;
	background: #537d96;
	color: #fff;
	font-size: 24rpx;
	font-weight: 800;
	padding: 0;
}

.thread-list {
	height: calc(100vh - 582rpx);
	min-height: 300rpx;
	margin-top: 0;
}

.thread-item {
	position: relative;
	display: flex;
	align-items: center;
	gap: 18rpx;
	min-height: 76rpx;
	padding: 12rpx 54rpx 12rpx 10rpx;
	margin-bottom: 12rpx;
	border-radius: 18rpx;
	background: transparent;
	border: 1rpx solid transparent;
	box-sizing: border-box;
}

.thread-item.active {
	border-color: transparent;
	background: #f4f4f4;
}

.thread-dot {
	width: 48rpx;
	height: 48rpx;
	line-height: 48rpx;
	border-radius: 50%;
	text-align: center;
	background: #e0f2fe;
	color: rgba(42, 38, 34, .65);
	font-size: 24rpx;
	font-weight: 900;
}

.thread-dot.color-0 { background: #e0f2fe; }
.thread-dot.color-1 { background: #ffe0ea; }
.thread-dot.color-2 { background: #dcfce7; }
.thread-dot.color-3 { background: #ecfccb; }
.thread-dot.color-4 { background: #ede9fe; }
.thread-dot.color-5 { background: #ccfbf1; }

.thread-copy {
	flex: 1;
	min-width: 0;
}

.thread-title {
	font-size: 28rpx;
	font-weight: 800;
	color: #111827;
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}

.thread-meta {
	margin-top: 8rpx;
	font-size: 20rpx;
	color: #6b6158;
}

.thread-del {
	position: absolute;
	right: 14rpx;
	top: 18rpx;
	width: 42rpx;
	height: 42rpx;
	line-height: 42rpx;
	text-align: center;
	border-radius: 50%;
	font-size: 30rpx;
	color: #a3a3a3;
}

.sidebar-bottom {
	position: absolute;
	left: 0;
	right: 0;
	bottom: 0;
	height: 104rpx;
	padding: 16rpx 22rpx 20rpx;
	box-sizing: border-box;
	display: flex;
	align-items: center;
	gap: 22rpx;
	background: rgba(255, 255, 255, .98);
	border-top: 1rpx solid #ececec;
}

.sidebar-bottom-user {
	flex: 1;
	min-width: 0;
	display: flex;
	align-items: center;
	gap: 14rpx;
	font-size: 28rpx;
	font-weight: 800;
	color: #111827;
}

.sidebar-bottom-icon {
	width: 52rpx;
	height: 52rpx;
	line-height: 52rpx;
	text-align: center;
	font-size: 36rpx;
	font-weight: 800;
	color: #111827;
}

.pet-chat-list {
	flex: 1;
	height: auto;
	max-height: none;
	min-height: 0;
	padding: 22rpx 24rpx;
	box-sizing: border-box;
	background: #f7f8fa;
	overflow: hidden;
}

.pet-chat-panel.is-fullscreen .pet-chat-list {
	flex: 1;
	min-height: 0;
	height: auto;
	max-height: none;
}

.chat-msg {
	display: flex;
	margin-bottom: 16rpx;
}

.chat-msg.user {
	justify-content: flex-end;
}

.chat-msg.assistant {
	justify-content: flex-start;
}

.chat-bubble {
	max-width: 78%;
	padding: 16rpx 20rpx;
	border-radius: 18rpx;
	font-size: 27rpx;
	line-height: 1.55;
	white-space: pre-wrap;
	word-break: break-word;
}

.pet-chat-panel.is-fullscreen .chat-bubble {
	max-width: 86%;
}

.chat-msg.user .chat-bubble {
	background: #ff2d62;
	color: #fff;
	border-bottom-right-radius: 6rpx;
}

.chat-msg.assistant .chat-bubble {
	background: #fff;
	color: #1f2937;
	border-bottom-left-radius: 6rpx;
	box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, .06);
}

.chat-bubble.loading {
	color: #8b9099;
}

.typing-text {
	color: inherit;
}

.typing-dots {
	display: inline;
}

.typing-dots .dot {
	display: inline;
	animation: typing-bounce 1.2s ease-in-out infinite;
	color: inherit;
	opacity: .5;
}

.typing-dots .dot1 { animation-delay: 0s; }
.typing-dots .dot2 { animation-delay: .2s; }
.typing-dots .dot3 { animation-delay: .4s; }

@keyframes typing-bounce {
	0%, 60%, 100% { opacity: .3; }
	30% { opacity: 1; }
}

.chat-image-grid {
	display: flex;
	flex-wrap: wrap;
	gap: 10rpx;
	margin-top: 12rpx;
}

.chat-image-thumb {
	width: 148rpx;
	height: 148rpx;
	border-radius: 12rpx;
	background: rgba(216, 207, 190, .35);
	border: 1rpx solid rgba(255, 255, 255, .5);
}

.pet-chat-panel.is-fullscreen .chat-image-thumb {
	width: 196rpx;
	height: 196rpx;
}

.quick-row {
	display: flex;
	gap: 12rpx;
	padding: 16rpx 22rpx 0;
	overflow-x: auto;
	white-space: nowrap;
}

.quick-chip {
	flex: 0 0 auto;
	background: #fff4f6;
	color: #9f1239;
	border-radius: 999rpx;
	padding: 10rpx 16rpx;
	font-size: 23rpx;
}

.pet-chat-input {
	display: flex;
	align-items: center;
	gap: 14rpx;
	padding: 14rpx 22rpx 20rpx;
	flex: none;
	background: rgba(251, 247, 238, .98);
}

.attach-btn {
	width: 72rpx;
	height: 72rpx;
	line-height: 68rpx;
	border-radius: 36rpx;
	background: #fff;
	color: #111827;
	border: 1rpx solid #d8dee8;
	font-size: 42rpx;
	font-weight: 600;
	padding: 0;
}

.attach-btn.is-disabled {
	color: #9ca3af;
	background: #f3f5f8;
}

.attach-preview {
	display: flex;
	gap: 10rpx;
	padding: 14rpx 22rpx 0;
	overflow-x: auto;
}

.attach-chip {
	display: flex;
	align-items: center;
	gap: 8rpx;
	max-width: 300rpx;
	background: #eef6f8;
	color: #1f6f82;
	border-radius: 999rpx;
	padding: 8rpx 14rpx 8rpx 8rpx;
	font-size: 23rpx;
	white-space: nowrap;
}

.attach-thumb {
	width: 44rpx;
	height: 44rpx;
	border-radius: 50%;
	background: rgba(216, 207, 190, .35);
}

.attach-chip text:first-child {
	overflow: hidden;
	text-overflow: ellipsis;
}

.attach-del {
	color: #dc2626;
	font-size: 28rpx;
	font-weight: 900;
}

.attach-clear-all {
	background: rgba(220, 38, 38, .08);
	color: #dc2626;
}

.chat-text-input {
	flex: 1;
	height: 72rpx;
	box-sizing: border-box;
	padding: 0 22rpx;
	border-radius: 36rpx;
	background: #f3f5f8;
	font-size: 26rpx;
}

.chat-send-btn {
	width: 128rpx;
	height: 72rpx;
	line-height: 72rpx;
	border-radius: 36rpx;
	background: #111827;
	color: #fff;
	font-size: 26rpx;
	font-weight: 800;
	padding: 0;
}

.chat-send-btn.is-disabled {
	background: #9ca3af;
	color: #fff;
}

.version-notice-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	z-index: 10020;
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 44rpx;
	box-sizing: border-box;
	background: rgba(42, 38, 34, .44);
}

.version-notice-panel {
	width: 100%;
	max-width: 620rpx;
	border-radius: 18rpx;
	overflow: hidden;
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 24rpx 80rpx rgba(42, 38, 34, .28);
}

.version-notice-title {
	padding: 34rpx 34rpx 0;
	text-align: center;
	font-size: 31rpx;
	font-weight: 900;
	color: #2a2622;
}

.version-notice-name {
	margin-top: 22rpx;
	padding: 0 34rpx;
	font-size: 28rpx;
	font-weight: 800;
	color: #3f6179;
	line-height: 1.45;
}

.version-notice-list {
	padding: 18rpx 34rpx 8rpx;
}

.version-notice-item {
	display: flex;
	align-items: flex-start;
	gap: 12rpx;
	margin-bottom: 14rpx;
	font-size: 26rpx;
	line-height: 1.55;
	color: #4c443c;
}

.version-notice-index {
	flex: 0 0 40rpx;
	font-weight: 900;
	color: #537d96;
}

.version-notice-text {
	flex: 1;
	word-break: break-word;
}

.version-notice-date {
	padding: 0 34rpx 28rpx;
	font-size: 23rpx;
	color: #6b6158;
}

.version-notice-actions {
	display: flex;
	border-top: 1rpx solid rgba(216, 207, 190, .72);
	background: rgba(255, 255, 255, .42);
}

.version-notice-actions text {
	flex: 1;
	height: 92rpx;
	line-height: 92rpx;
	text-align: center;
	font-size: 27rpx;
	font-weight: 800;
	color: #2a2622;
}

.version-notice-actions text + text {
	border-left: 1rpx solid rgba(216, 207, 190, .72);
	color: #537d96;
}

@keyframes chat-in {
	from {
		opacity: 0;
		transform: translateY(24rpx);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

/* Warm paper overrides */
.pet-img {
	filter: drop-shadow(0 10rpx 10rpx rgba(42, 38, 34, .14));
}

.cat-shadow {
	background: rgba(42, 38, 34, .18);
}

.pet-bubble {
	background: rgba(42, 38, 34, .88);
	box-shadow: 0 14rpx 30rpx rgba(42, 38, 34, .14);
}

.pet-chat-mask {
	background: rgba(42, 38, 34, .22);
}

.pet-chat-panel {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 24rpx 60rpx rgba(42, 38, 34, .2);
}

.pet-chat-head {
	border-bottom-color: rgba(216, 207, 190, .72);
}

.pet-chat-title {
	color: #2a2622;
}

.chat-msg.assistant .chat-bubble {
	color: #2a2622;
}

.chat-bubble.loading {
	color: #6b6158;
}

.typing-dots .dot {
	opacity: .4;
}

.pet-chat-actions {
	color: #537d96;
}

.pet-chat-list {
	background: #f5efe4;
	background-image: linear-gradient(90deg, rgba(122, 96, 68, .035) 1rpx, transparent 1rpx);
	background-size: 48rpx 48rpx;
}

/* B11: User bubble — brand gradient handled by .chat-msg.user .chat-bubble above */
.chat-msg.user .chat-bubble {
	background: linear-gradient(135deg, #537d96, #476d83);
	color: #fff;
}

/* B11: Assistant bubble — warm paper style */
.chat-msg.assistant .chat-bubble {
	background: rgba(255, 255, 255, .92);
	border: 1rpx solid rgba(216, 207, 190, .6);
	box-shadow: 0 4rpx 16rpx rgba(42, 38, 34, .06);
}

.quick-chip {
	background: rgba(83, 125, 150, .08);
	color: #3f6179;
}

.chat-text-input {
	background: rgba(216, 207, 190, .25);
	border: 1rpx solid rgba(216, 207, 190, .72);
	color: #2a2622;
}

.chat-send-btn {
	background: linear-gradient(135deg, #537d96, #476d83);
}

.chat-send-btn.is-disabled {
	opacity: .45;
}

.agent-info-mask {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	z-index: 10030;
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 44rpx;
	box-sizing: border-box;
	background: rgba(42, 38, 34, .45);
}

.agent-info-panel {
	width: 100%;
	max-width: 620rpx;
	max-height: 82vh;
	overflow: hidden;
	border-radius: 18rpx;
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 24rpx 80rpx rgba(42, 38, 34, .28);
}

.agent-info-title {
	padding: 32rpx 34rpx 0;
	text-align: center;
	font-size: 31rpx;
	font-weight: 900;
	color: #2a2622;
}

.agent-info-version {
	padding: 14rpx 34rpx 22rpx;
	text-align: center;
	font-size: 26rpx;
	font-weight: 800;
	color: #537d96;
}

.agent-info-meta {
	margin: 0 30rpx;
	border-radius: 12rpx;
	overflow: hidden;
	border: 1rpx solid rgba(216, 207, 190, .72);
}

.agent-info-row {
	display: flex;
	gap: 18rpx;
	padding: 18rpx 20rpx;
	background: rgba(255, 255, 255, .4);
	border-bottom: 1rpx solid rgba(216, 207, 190, .58);
	font-size: 24rpx;
	line-height: 1.45;
}

.agent-info-row:last-child {
	border-bottom: 0;
}

.agent-info-row text:first-child {
	flex: 0 0 116rpx;
	color: #6b6158;
	font-weight: 800;
}

.agent-info-row text:last-child {
	flex: 1;
	min-width: 0;
	color: #2a2622;
	word-break: break-word;
}

.agent-info-log-title {
	padding: 26rpx 34rpx 12rpx;
	font-size: 27rpx;
	font-weight: 900;
	color: #2a2622;
}

.agent-info-log {
	padding: 0 34rpx 18rpx;
}

.agent-info-log-item {
	display: flex;
	align-items: flex-start;
	gap: 12rpx;
	margin-bottom: 14rpx;
	font-size: 25rpx;
	line-height: 1.52;
	color: #4c443c;
}

.agent-info-log-index {
	flex: 0 0 36rpx;
	width: 36rpx;
	height: 36rpx;
	line-height: 36rpx;
	border-radius: 50%;
	background: rgba(83, 125, 150, .12);
	color: #537d96;
	text-align: center;
	font-size: 22rpx;
	font-weight: 900;
}

.agent-info-log-text {
	flex: 1;
	word-break: break-word;
}

.agent-info-actions {
	border-top: 1rpx solid rgba(216, 207, 190, .72);
