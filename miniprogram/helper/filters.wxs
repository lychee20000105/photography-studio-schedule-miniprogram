/**
 * B26: Shared WXS filters for view-layer formatting
 * Usage in WXML: <wxs src="../../helper/filters.wxs" module="f" />
 * Then: {{f.fmtDate(item.ORDER_DATE)}}
 */

// Format date: "2026-06-25" → "6月25日"
function fmtDate(dateStr) {
  if (!dateStr) return '';
  var parts = dateStr.split('-');
  if (parts.length < 3) return dateStr;
  var m = parseInt(parts[1], 10);
  var d = parseInt(parts[2], 10);
  return m + '月' + d + '日';
}

// Format date short: "2026-06-25" → "6/25"
function fmtDateShort(dateStr) {
  if (!dateStr) return '';
  var parts = dateStr.split('-');
  if (parts.length < 3) return dateStr;
  return parseInt(parts[1], 10) + '/' + parseInt(parts[2], 10);
}

// Format amount: 12345.6 → "12,345.60"
function fmtAmount(val) {
  if (val === undefined || val === null || val === '') return '0.00';
  var num = parseFloat(val);
  if (isNaN(num)) return '0.00';
  var parts = num.toFixed(2).split('.');
  parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  return parts.join('.');
}

// Format amount with ¥ prefix
function fmtMoney(val) {
  return '¥' + fmtAmount(val);
}

// Status text mapping for orders
var ORDER_STATUS_MAP = {
  '0': '待确认',
  '1': '已确认',
  '2': '已完成',
  '3': '已取消'
};

function fmtOrderStatus(status) {
  return ORDER_STATUS_MAP[status + ''] || '未知';
}

module.exports = {
  fmtDate: fmtDate,
  fmtDateShort: fmtDateShort,
  fmtAmount: fmtAmount,
  fmtMoney: fmtMoney,
  fmtOrderStatus: fmtOrderStatus
};
