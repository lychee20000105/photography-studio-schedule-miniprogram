page {
	background: #f6f7f9;
}

.page {
	padding: 28rpx;
}

.guest-banner {
	margin-bottom: 20rpx;
	padding: 20rpx 22rpx;
	border-radius: 14rpx;
	background: #111827;
	color: #fff;
	font-size: 25rpx;
	line-height: 1.45;
}

.head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 24rpx;
	background: linear-gradient(135deg, #1f2937, #111827);
	border-radius: 24rpx;
	padding: 34rpx 30rpx;
	box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, .12);
}

.head-main {
	min-width: 0;
}

.eyebrow {
	margin-bottom: 8rpx;
	font-size: 23rpx;
	color: rgba(255, 255, 255, .68);
}

.title {
	font-size: 42rpx;
	font-weight: 900;
	color: #fff;
}

.sub {
	margin-top: 10rpx;
	font-size: 25rpx;
	color: rgba(255, 255, 255, .72);
}

.add-btn {
	flex-shrink: 0;
	background: #ff6b6b;
	color: #fff;
	border-radius: 999rpx;
	padding: 22rpx 30rpx;
	font-size: 29rpx;
	font-weight: 800;
	box-shadow: 0 10rpx 24rpx rgba(255, 107, 107, .35);
}

.filters {
	display: flex;
	align-items: center;
	gap: 16rpx;
	margin-top: 22rpx;
}

.tab,
.month,
.quick-item {
	background: #fff;
	border-radius: 999rpx;
	padding: 16rpx 28rpx;
	font-size: 27rpx;
	color: #6b7280;
}

.tab.cur {
	background: #1f2937;
	color: #fff;
	font-weight: 700;
}

.month {
	color: #1f2937;
}

.summary {
	display: flex;
	gap: 16rpx;
	margin-top: 18rpx;
}

.summary-item {
	flex: 1;
	background: #fff;
	border-radius: 18rpx;
	padding: 22rpx 24rpx;
	box-shadow: 0 8rpx 26rpx rgba(15, 23, 42, .04);
}

.summary-num {
	font-size: 38rpx;
	font-weight: 900;
	color: #1f2937;
}

.summary-label {
	margin-top: 4rpx;
	font-size: 24rpx;
	color: #8b9099;
}

.quick {
	margin-top: 22rpx;
	background: #fff;
	border-radius: 18rpx;
	padding: 20rpx;
	box-shadow: 0 8rpx 26rpx rgba(15, 23, 42, .04);
}

.quick-title {
	font-size: 24rpx;
	color: #9ca3af;
}

.quick-actions {
	display: flex;
	gap: 16rpx;
	margin-top: 14rpx;
}

.quick-item {
	flex: 1;
	text-align: center;
	background: #f6f7f9;
}

.list {
	margin-top: 22rpx;
}

.order {
	background: #fff;
	border-radius: 18rpx;
	padding: 26rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 8rpx 26rpx rgba(15, 23, 42, .05);
}

.order-top,
.money {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12rpx;
}

.customer {
	font-size: 34rpx;
	font-weight: 900;
	color: #1f2937;
}

.status {
	font-size: 24rpx;
	color: #ff6b6b;
	background: #fff1f1;
	border-radius: 999rpx;
	padding: 8rpx 16rpx;
}

.line {
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 14rpx;
	margin-top: 18rpx;
	font-size: 26rpx;
	color: #6b7280;
}

.date.undated {
	color: #f97316;
	font-weight: 700;
}

.type {
	color: #fff;
	border-radius: 8rpx;
	padding: 6rpx 12rpx;
	font-size: 24rpx;
}

.money {
	margin-top: 22rpx;
	font-size: 24rpx;
	color: #8b9099;
}

.money text {
	display: block;
	margin-top: 6rpx;
	font-size: 28rpx;
	font-weight: 800;
	color: #1f2937;
}

.money .paid {
	color: #16a34a;
}

.money .unpaid {
	color: #dc2626;
}

.settle {
	margin-top: 18rpx;
	font-size: 24rpx;
	color: #9ca3af;
	background: #f9fafb;
	border-radius: 12rpx;
	padding: 12rpx 14rpx;
}

.empty {
	margin-top: 120rpx;
	text-align: center;
	color: #9ca3af;
	font-size: 28rpx;
}

.empty-btn {
	display: inline-block;
	margin-top: 28rpx;
	background: #ff6b6b;
	color: #fff;
	border-radius: 999rpx;
	padding: 18rpx 34rpx;
}

/* Warm paper overrides */
page {
	background-color: #f5efe4;
	background-image:
		linear-gradient(90deg, rgba(122, 96, 68, .035) 1rpx, transparent 1rpx),
		linear-gradient(180deg, rgba(255, 253, 247, .56), rgba(216, 207, 190, .22));
	background-size: 48rpx 48rpx, 100% 100%;
	color: #2a2622;
}

.page {
	padding-bottom: 150rpx;
}

.guest-banner,
.head,
.summary-item,
.quick,
.order {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 12rpx 38rpx rgba(42, 38, 34, .06);
}

.guest-banner,
.head {
	color: #2a2622;
}

.head {
	border-radius: 12rpx;
}

.eyebrow,
.sub,
.summary-label,
.quick-title,
.line,
.money,
.settle,
.empty {
	color: #6b6158;
}

.title,
.summary-num,
.customer,
.money text,
.month {
	color: #2a2622;
}

.add-btn,
.tab.cur,
.empty-btn {
	background: #537d96;
	color: #fff;
	box-shadow: 0 8rpx 22rpx rgba(83, 125, 150, .2);
}

.filters {
	flex-wrap: wrap;
}

.tab,
.month,
.quick-item {
	background: rgba(251, 247, 238, .92);
	border: 1rpx solid #d8cfbe;
	color: #6b6158;
}

.quick-item {
	background: rgba(83, 125, 150, .06);
	color: #3f6179;
}

.summary-item,
.quick,
.order {
	border-radius: 10rpx;
}

.status {
	background: rgba(83, 125, 150, .08);
	color: #3f6179;
}

.money .paid {
	color: #4a6b4a;
}

.money .unpaid,
.date.undated {
	color: #8b2c1f;
}

.settle {
	background: rgba(216, 207, 190, .26);
}
