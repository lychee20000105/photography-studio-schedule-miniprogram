page{background:#f6f7f9}.page{padding:24rpx}.filters{display:flex;gap:12rpx;margin-bottom:18rpx}.filters picker{flex:1;background:#fff;border-radius:14rpx;padding:22rpx;text-align:center;font-weight:900}.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-bottom:18rpx}.summary>view,.block,.card{background:#fff;border-radius:14rpx;padding:22rpx}.summary>view{text-align:center}.summary text{font-size:22rpx;color:#8b9099}.summary view view{font-size:30rpx;font-weight:900;color:#111827;margin-top:8rpx}.row{display:flex;align-items:center;border-bottom:1rpx solid #edf0f4;min-height:78rpx}.row text{width:100rpx;font-weight:800}.row input{flex:1;text-align:right}.pay{margin-top:20rpx;background:#ff2d62;color:#fff;border-radius:12rpx}.section{font-size:32rpx;font-weight:900;margin:28rpx 0 14rpx}.card{position:relative;padding-right:160rpx;margin-bottom:16rpx}.title{font-size:30rpx;font-weight:900;color:#111827}.meta{font-size:24rpx;color:#8b9099;margin-top:8rpx}.amount{position:absolute;right:22rpx;top:26rpx;color:#ff2d62;font-weight:900}.danger{color:#dc2626}.muted{color:#6b7280}.empty{text-align:center;color:#8b9099;padding:40rpx 0}