<view class="page"><view class="filters"><picker mode="date" fields="month" value="{{month}}" bindchange="bindMonthChange"><view>{{month}}</view></picker><input placeholder="员工ID" value="{{staffId}}" data-field="staffId" bindinput="bindInput"/><input placeholder="CURRENT/FROZEN" value="{{kind}}" data-field="kind" bindinput="bindInput"/><button bindtap="_loadList">查</button></view><view wx:if="{{list.length==0}}" class="empty">暂无提成</view><view wx:for="{{list}}" wx:key="_id" class="card"><view class="title">{{item.COMMISSION_STAFF_NAME}}｜{{item.COMMISSION_KIND}}</view><view class="meta">{{item.COMMISSION_MONTH}} · {{item.COMMISSION_ORDER_TYPE_NAME}} · {{item.COMMISSION_CUSTOMER_SURNAME||item.COMMISSION_CUSTOMER_NAME}}</view><view class="amount {{item.COMMISSION_AMOUNT_CENT<0?'danger':''}}">¥{{item.COMMISSION_AMOUNT}}</view></view></view>

<tech-footer />
<work-pet id="workPet" />