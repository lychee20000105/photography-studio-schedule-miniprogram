<view class="play-page">
  <view class="intro" wx:if="{{!playing && !result}}">
    <text class="game-title">{{gameInfo.name}}</text>
    <text class="game-desc">{{gameInfo.desc}}</text>
  </view>

  <block wx:if="{{gameId === 'care'}}">
    <view class="care-board" wx:if="{{gameState}}">
      <view class="care-cat">
        <view class="cat-head">
          <view class="cat-ear left"></view>
          <view class="cat-ear right"></view>
          <view class="cat-eye"></view>
          <view class="cat-eye"></view>
          <view class="cat-mouth"></view>
        </view>
      </view>
      <text class="care-score">当前状态 {{careScore}}</text>
      <view class="care-grid">
        <view class="care-stat"><text>饱腹</text><text>{{gameState.care.hunger}}</text></view>
        <view class="care-stat"><text>心情</text><text>{{gameState.care.mood}}</text></view>
        <view class="care-stat"><text>体力</text><text>{{gameState.care.energy}}</text></view>
        <view class="care-stat"><text>清洁</text><text>{{gameState.care.clean}}</text></view>
      </view>
      <view class="action-list">
        <view class="action" wx:for="{{careActions}}" wx:key="id" data-id="{{item.id}}" bind:tap="onCareActionTap">
          <text class="action-name">{{item.name}}</text>
          <text class="action-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{gameId === 'tower'}}">
    <view class="tower-hud">
      <view><text>波次</text><text>{{wave}} / 5</text></view>
      <view><text>生命</text><text>{{lives}}</text></view>
      <view><text>金币</text><text>{{coins}}</text></view>
      <view><text>得分</text><text>{{score}}</text></view>
    </view>

    <view class="tower-select">
      <view class="tower-type {{selectedTower === item.id ? 'active' : ''}}" wx:for="{{towerTypes}}" wx:key="id" data-id="{{item.id}}" bind:tap="onSelectTower">
        <text class="tower-short">{{item.short}}</text>
        <text class="tower-name">{{item.name}}</text>
        <text class="tower-cost">{{item.cost}}金币</text>
      </view>
    </view>

    <view class="battlefield">
      <view class="path p1"></view>
      <view class="path p2"></view>
      <view class="path p3"></view>
      <view class="path p4"></view>
      <view class="base start">入口</view>
      <view class="base end">店铺</view>

      <view class="slot" wx:for="{{towerSlots}}" wx:key="id" style="left: {{item.x}}%; top: {{item.y}}%;" data-id="{{item.id}}" bind:tap="onSlotTap">+</view>
      <view class="tower" wx:for="{{towers}}" wx:key="slotId" style="left: {{item.x}}%; top: {{item.y}}%;">
        <text>{{item.short}}</text>
      </view>
      <view class="enemy {{item.id}}" wx:for="{{enemies}}" wx:key="uid" style="left: {{item.x}}%; top: {{item.y}}%;">
        <text>{{item.short}}</text>
        <view class="hp"><view class="hp-fill" style="width: {{item.hp * 100 / item.maxHp}}%"></view></view>
      </view>
    </view>

    <text class="log">{{logText}}</text>
    <view class="start-btn" wx:if="{{!playing}}" bind:tap="onStartTower">开始守店</view>
  </block>

  <view class="result-modal" wx:if="{{result}}">
    <view class="result-card">
      <text class="result-title">{{result.win ? '守店成功' : '本轮结束'}}</text>
      <text class="result-line">得分 {{result.score}}</text>
      <text class="result-line">奖励 +{{result.coins}}金币 +{{result.exp}}经验</text>
      <view class="result-btn" bind:tap="onResultBack">返回小游戏</view>
    </view>
  </view>
</view>
