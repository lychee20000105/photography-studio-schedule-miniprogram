/* ===== 全局 ===== */
page {
  --c-pri: #ff6b6b;
  --c-pri-end: #ffa07a;
  --c-bg: #f5efe4;
  --c-card: #fff;
  --c-text: #333;
  --c-sub: #999;
  background: var(--c-bg);
  min-height: 100vh;
}

.play-container {
  padding: 24rpx;
  position: relative;
}

/* ===== 开始界面 ===== */
.game-header-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  animation: slideUp 0.4s ease-out both;
}

.game-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--c-pri), var(--c-pri-end));
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.game-icon {
  font-size: 48rpx;
}

.game-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 8rpx;
}

.game-desc {
  display: block;
  font-size: 26rpx;
  color: var(--c-sub);
}

/* 规则卡片 */
.rules-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  animation: slideUp 0.4s ease-out 0.1s both;
}

.rules-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 16rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.rule-bullet {
  color: var(--c-pri);
  font-weight: 700;
  margin-right: 12rpx;
  font-size: 28rpx;
  line-height: 36rpx;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
  line-height: 36rpx;
  flex: 1;
}

/* 开始按钮 */
.start-btn {
  background: linear-gradient(135deg, var(--c-pri), var(--c-pri-end));
  border-radius: 48rpx;
  padding: 26rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(255,107,107,0.3);
  animation: slideUp 0.4s ease-out 0.2s both;
  transition: transform 0.12s ease;
}

.start-btn:active {
  transform: scale(0.95);
}

.start-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 游戏中 - 顶部栏 ===== */
.play-header {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.play-timer,
.play-score,
.play-combo {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 14rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.hdr-label {
  display: block;
  font-size: 20rpx;
  color: var(--c-sub);
}

.hdr-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--c-pri);
}

.play-timer.danger {
  animation: timerPulse 0.6s ease-in-out infinite alternate;
  border: 2rpx solid rgba(255,60,60,0.4);
}

.play-timer.danger .hdr-value {
  color: #e53e3e;
}

/* ===== 命中反馈 ===== */
.hit-feedback {
  position: fixed;
  top: 35%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 95;
  pointer-events: none;
  opacity: 0;
}

.hit-feedback.show {
  animation: hitPop 0.6s ease-out forwards;
}

.hit-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffb300;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
  white-space: nowrap;
}

/* ===== 屏幕效果 ===== */
.play-container.shake {
  animation: screenShake 0.15s linear;
}

.screen-flash {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.5);
  z-index: 100;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.08s ease;
}

.screen-flash.show {
  opacity: 1;
}

/* ===== 打地鼠 Canvas ===== */
.game-canvas {
  width: 100%;
  height: 600rpx;
  background: #e8f4f8;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.play-tip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--c-sub);
  padding: 16rpx;
}

/* ===== 记忆翻牌 ===== */
.mem-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 8rpx;
}

.mem-card {
  aspect-ratio: 1;
  perspective: 800rpx;
  cursor: pointer;
}

.mem-card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.4s ease;
}

.mem-card.flipped .mem-card-inner,
.mem-card.matched .mem-card-inner {
  transform: rotateY(180deg);
}

.mem-card-front,
.mem-card-back {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  backface-visibility: hidden;
}

.mem-card-back {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.mem-back {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.mem-card-front {
  background: #fff;
  transform: rotateY(180deg);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.08);
}

.mem-face {
  font-size: 48rpx;
}

.mem-card.matched .mem-card-front {
  background: #f0fff4;
  border: 2rpx solid #48bb78;
}

/* ===== 合成2048 ===== */
.t-wrap {
  width: 550rpx;
  height: 550rpx;
  margin: 0 auto 16rpx;
  background: #bbada0;
  border-radius: 16rpx;
  padding: 12rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.t-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  width: 100%;
  height: 100%;
}

.t-cell {
  background: rgba(238, 228, 218, 0.35);
  border-radius: 12rpx;
}

.t-tile {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.12s ease;
  z-index: 2;
}

.t-tile-num {
  font-size: 40rpx;
  font-weight: 700;
}

/* 2048 颜色 */
.t-v0    { background: #cdc1b4; color: #776e65; }
.t-v2    { background: #eee4da; color: #776e65; }
.t-v4    { background: #ede0c8; color: #776e65; }
.t-v8    { background: #f2b179; color: #f9f6f2; }
.t-v16   { background: #f59563; color: #f9f6f2; }
.t-v32   { background: #f67c5f; color: #f9f6f2; }
.t-v64   { background: #f65e3b; color: #f9f6f2; }
.t-v128  { background: #edcf72; color: #f9f6f2; }
.t-v128 .t-tile-num { font-size: 36rpx; }
.t-v256  { background: #edcc61; color: #f9f6f2; }
.t-v256 .t-tile-num { font-size: 36rpx; }
.t-v512  { background: #edc850; color: #f9f6f2; }
.t-v512 .t-tile-num { font-size: 36rpx; }
.t-v1024 { background: #edc53f; color: #f9f6f2; }
.t-v1024 .t-tile-num { font-size: 30rpx; }
.t-v2048 { background: #edc22e; color: #f9f6f2; }
.t-v2048 .t-tile-num { font-size: 30rpx; }

.t-tile.merged {
  animation: tileMerge 0.2s ease;
}

.t-tile.tile-new {
  animation: tileAppear 0.2s ease;
}

.t-info {
  text-align: center;
  padding: 8rpx;
}

.t-best {
  font-size: 24rpx;
  color: var(--c-sub);
}

/* ===== 结算弹窗 ===== */
.result-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease-out;
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 560rpx;
  text-align: center;
  animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
  position: relative;
  z-index: 2;
}

.result-emoji {
  display: block;
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--c-text);
  margin-bottom: 8rpx;
}

.result-score {
  display: block;
  font-size: 28rpx;
  color: var(--c-sub);
  margin-bottom: 28rpx;
}

.result-rewards {
  margin-bottom: 32rpx;
}

.rw-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  animation: scaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.rw-row:nth-child(1) { animation-delay: 0.1s; }
.rw-row:nth-child(2) { animation-delay: 0.2s; }
.rw-row:nth-child(3) { animation-delay: 0.3s; }
.rw-row:nth-child(4) { animation-delay: 0.4s; }

.rw-icon {
  font-size: 30rpx;
}

.rw-val {
  font-size: 28rpx;
  color: var(--c-pri);
  font-weight: 600;
}

.result-btn {
  background: linear-gradient(135deg, var(--c-pri), var(--c-pri-end));
  color: #fff;
  border-radius: 40rpx;
  padding: 18rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  transition: transform 0.12s ease;
}

.result-btn:active {
  transform: scale(0.95);
}

/* ===== 倒计时 ===== */
.countdown-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 998;
}

.countdown-number {
  font-size: 160rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 4rpx 20rpx rgba(255,107,107,0.5);
}

.countdown-number.zoom {
  animation: countdownZoom 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ===== 彩纸 ===== */
.confetti-wrap {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

.confetti {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  opacity: 0;
}

.confetti.c1 { left: 10%; background: #ff6b6b; animation: confettiFall 2.5s 0s ease-out forwards; }
.confetti.c2 { left: 30%; background: #ffa07a; animation: confettiFall 2.5s 0.2s ease-out forwards; width: 20rpx; height: 10rpx; }
.confetti.c3 { left: 50%; background: #ffe066; animation: confettiFall 2.5s 0.4s ease-out forwards; border-radius: 50%; }
.confetti.c4 { left: 65%; background: #a18cd1; animation: confettiFall 2.5s 0.1s ease-out forwards; }
.confetti.c5 { left: 80%; background: #fbc2eb; animation: confettiFall 2.5s 0.3s ease-out forwards; width: 12rpx; height: 24rpx; }
.confetti.c6 { left: 45%; background: #81ecec; animation: confettiFall 2.5s 0.5s ease-out forwards; border-radius: 50%; }

/* ===== 动画 ===== */
@keyframes slideUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.5); }
  to   { opacity: 1; transform: scale(1); }
}

@keyframes countdownZoom {
  0%   { transform: scale(2.5); opacity: 0.3; }
  40%  { transform: scale(0.85); opacity: 1; }
  70%  { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes screenShake {
  0%   { transform: translateX(0); }
  25%  { transform: translateX(-6rpx); }
  50%  { transform: translateX(6rpx); }
  75%  { transform: translateX(-4rpx); }
  100% { transform: translateX(0); }
}

@keyframes timerPulse {
  0%   { box-shadow: 0 0 0 rgba(255,60,60,0); }
  100% { box-shadow: 0 0 20rpx rgba(255,60,60,0.35); }
}

@keyframes hitPop {
  0%   { opacity: 1; transform: translate(-50%, -50%) scale(0.5); }
  30%  { opacity: 1; transform: translate(-50%, -60%) scale(1.2); }
  100% { opacity: 0; transform: translate(-50%, -100%) scale(1); }
}

@keyframes tileMerge {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.2); }
  100% { transform: scale(1); }
}

@keyframes tileAppear {
  0%   { opacity: 0; transform: scale(0); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes confettiFall {
  0%   { opacity: 1; top: -20rpx; transform: rotateZ(0deg) translateX(0); }
  25%  { transform: rotateZ(90deg) translateX(30rpx); }
  50%  { transform: rotateZ(180deg) translateX(-20rpx); }
  75%  { opacity: 0.8; transform: rotateZ(270deg) translateX(15rpx); }
  100% { opacity: 0; top: 100vh; transform: rotateZ(360deg) translateX(-10rpx); }
}
