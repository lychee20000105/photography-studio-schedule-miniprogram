page {
  background: #f5efe4;
  color: #2f2a25;
  min-height: 100vh;
}

.play-page {
  padding: 24rpx;
}

.intro {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.game-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
}

.game-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #746b60;
}

.care-board {
  background: #fffdf8;
  border-radius: 24rpx;
  padding: 30rpx;
}

.care-cat {
  height: 230rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-head {
  width: 160rpx;
  height: 136rpx;
  border-radius: 70rpx 70rpx 56rpx 56rpx;
  background: #f3c56d;
  position: relative;
  box-shadow: inset 0 -10rpx 0 rgba(0,0,0,0.06);
}

.cat-ear {
  position: absolute;
  top: -32rpx;
  width: 58rpx;
  height: 58rpx;
  background: #f3c56d;
  transform: rotate(45deg);
  border-radius: 12rpx;
}

.cat-ear.left { left: 18rpx; }
.cat-ear.right { right: 18rpx; }

.cat-eye {
  position: absolute;
  top: 58rpx;
  width: 16rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #312820;
}

.cat-eye:nth-of-type(3) { left: 48rpx; }
.cat-eye:nth-of-type(4) { right: 48rpx; }

.cat-mouth {
  position: absolute;
  left: 70rpx;
  top: 88rpx;
  width: 22rpx;
  height: 10rpx;
  border-bottom: 4rpx solid #312820;
  border-radius: 50%;
}

.care-score {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 22rpx;
}

.care-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.care-stat {
  background: #f7efe2;
  border-radius: 16rpx;
  padding: 18rpx;
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
}

.action-list {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action {
  background: #537d96;
  color: #fff;
  border-radius: 18rpx;
  padding: 22rpx;
}

.action-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.action-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.86;
}

.tower-hud {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tower-hud view {
  background: #fff;
  border-radius: 14rpx;
  padding: 12rpx 8rpx;
  text-align: center;
}

.tower-hud text {
  display: block;
  font-size: 22rpx;
}

.tower-hud text:last-child {
  font-size: 30rpx;
  font-weight: 700;
  color: #537d96;
}

.tower-select {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.tower-type {
  flex: 1;
  background: #ffffff;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  padding: 14rpx 10rpx;
  text-align: center;
}

.tower-type.active {
  border-color: #537d96;
  background: #e8f2f6;
}

.tower-short {
  display: block;
  width: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  border-radius: 50%;
  margin: 0 auto 8rpx;
  background: #537d96;
  color: #fff;
}

.tower-name,
.tower-cost {
  display: block;
  font-size: 22rpx;
}

.tower-cost {
  color: #8a7b69;
}

.battlefield {
  height: 650rpx;
  position: relative;
  background: linear-gradient(180deg, #d7ead8, #edf3d2);
  border-radius: 24rpx;
  overflow: hidden;
  border: 4rpx solid #fff;
}

.path {
  position: absolute;
  background: #b99567;
  border-radius: 999rpx;
}

.p1 { left: 2%; top: 47%; width: 24%; height: 8%; }
.p2 { left: 21%; top: 17%; width: 8%; height: 38%; }
.p3 { left: 24%; top: 17%; width: 34%; height: 8%; }
.p4 { left: 52%; top: 17%; width: 8%; height: 46%; }

.base {
  position: absolute;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 22rpx;
}

.base.start { left: 3%; top: 40%; }
.base.end { right: 3%; top: 34%; background: #537d96; color: #fff; }

.slot,
.tower,
.enemy {
  position: absolute;
  transform: translate(-50%, -50%);
}

.slot {
  width: 58rpx;
  height: 58rpx;
  line-height: 54rpx;
  border-radius: 50%;
  border: 3rpx dashed rgba(83, 125, 150, 0.65);
  color: #537d96;
  text-align: center;
  font-size: 34rpx;
  background: rgba(255,255,255,0.45);
}

.tower {
  width: 66rpx;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 50%;
  background: #537d96;
  color: #fff;
  text-align: center;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.18);
}

.enemy {
  width: 60rpx;
  height: 60rpx;
  line-height: 54rpx;
  border-radius: 16rpx;
  background: #f08c5a;
  color: #fff;
  text-align: center;
  font-weight: 700;
  border: 3rpx solid rgba(255,255,255,0.8);
}

.enemy.change { background: #bd7ac8; }
.enemy.complaint { background: #c85656; }

.hp {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  bottom: -10rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: rgba(0,0,0,0.2);
  overflow: hidden;
}

.hp-fill {
  height: 100%;
  background: #54d17a;
}

.log {
  display: block;
  margin: 16rpx 0;
  text-align: center;
  color: #655c52;
  font-size: 26rpx;
}

.start-btn {
  background: #537d96;
  color: #fff;
  border-radius: 44rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.result-card {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
}

.result-title,
.result-line {
  display: block;
}

.result-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.result-line {
  font-size: 28rpx;
  color: #655c52;
  margin-top: 10rpx;
}

.result-btn {
  margin-top: 28rpx;
  background: #537d96;
  color: #fff;
  border-radius: 36rpx;
  padding: 18rpx 0;
}
