page { background: #f5efe4; min-height: 100vh; }

.play-container { padding: 24rpx; }

/* 游戏卡片 */
.game-header-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.game-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.game-title { font-size: 36rpx; font-weight: 600; color: #333; display: block; margin-bottom: 12rpx; }
.game-desc-full { font-size: 26rpx; color: #888; display: block; }

/* 规则 */
.game-rules {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
}
.rules-title { font-size: 28rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }
.rule-line { font-size: 26rpx; color: #666; display: block; margin-bottom: 8rpx; }

/* 开始按钮 */
.start-btn {
  background: linear-gradient(135deg, #ff6b6b, #ffa07a);
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(255,107,107,0.3);
}
.start-text { font-size: 32rpx; color: #fff; font-weight: 600; }

/* 游戏中 */
.play-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.play-timer, .play-score {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  min-width: 180rpx;
  text-align: center;
}
.timer-label, .score-label { font-size: 22rpx; color: #999; display: block; }
.timer-value { font-size: 40rpx; font-weight: 700; color: #ff6b6b; }
.score-value { font-size: 40rpx; font-weight: 700; color: #ff6b6b; }

.game-canvas {
  width: 100%;
  height: 600rpx;
  background: #e8f4f8;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.play-tip {
  text-align: center;
  font-size: 28rpx;
  color: #888;
  padding: 24rpx;
}

/* 结算弹窗 */
.result-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  width: 560rpx;
  text-align: center;
}
.result-title { font-size: 36rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }
.result-score { font-size: 28rpx; color: #888; display: block; margin-bottom: 24rpx; }
.result-rewards { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 32rpx; }
.reward-item { display: flex; align-items: center; justify-content: center; gap: 8rpx; }
.reward-icon { font-size: 32rpx; }
.reward-value { font-size: 28rpx; color: #ff6b6b; font-weight: 600; }
.result-btn {
  background: linear-gradient(135deg, #ff6b6b, #ffa07a);
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}
