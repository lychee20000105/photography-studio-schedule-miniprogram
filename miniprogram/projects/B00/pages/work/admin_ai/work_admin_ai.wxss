/* work_admin_ai.wxss — CC Switch style multi-provider AI config */
page {
  background-color: #f5efe4;
  background-image:
    linear-gradient(90deg, rgba(122, 96, 68, .035) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 253, 247, .56), rgba(216, 207, 190, .22));
  background-size: 48rpx 48rpx, 100% 100%;
  color: #2a2622;
}

.page {
  padding: 24rpx 24rpx 150rpx;
}

.block {
  background: #fbf7ee;
  border: 1rpx solid #d8cfbe;
  border-radius: 10rpx;
  box-shadow: 0 12rpx 38rpx rgba(42, 38, 34, .06);
  padding: 26rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.empty {
  color: #6b6158;
  text-align: center;
  padding: 80rpx 0;
}

.empty-sm {
  color: #6b6158;
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
}

/* ── 1. Header ── */
.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.head-left {
  flex: 1;
  min-width: 0;
}

.head-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #2a2622;
}

.head-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #6b6158;
}

/* ── 2. Active provider card ── */
.active-card {
  position: relative;
  transition: all .15s;
}

.active-inner {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(216, 207, 190, .72);
}

.active-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  background: #537d96;
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.active-info {
  flex: 1;
  min-width: 0;
}

.active-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.active-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #2a2622;
}

.active-badge {
  display: inline-flex;
  align-items: center;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 6rpx;
  background: #537d96;
  color: #fff;
  font-size: 20rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.active-url {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b6158;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.active-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 6rpx;
}

.meta-model {
  font-size: 24rpx;
  color: #2a2622;
  font-weight: 800;
}

.key-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.key-dot.green {
  background: #22c55e;
}

.key-dot.gray {
  background: #a8a29e;
}

.meta-key {
  font-size: 22rpx;
  color: #6b6158;
}

.active-arrow {
  font-size: 44rpx;
  color: #a8a29e;
  flex-shrink: 0;
  line-height: 1;
  padding-left: 8rpx;
}

.active-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 16rpx;
}

.action-btn {
  flex: 1;
  margin: 0;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 8rpx;
  background: rgba(216, 207, 190, .30);
  color: #2a2622;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.action-btn::after {
  border: 0;
}

.action-btn.primary {
  background: #537d96;
  color: #fff;
}

/* ── Provider switch dropdown ── */
.switch-panel {
  margin-top: -12rpx;
}

.switch-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #2a2622;
  margin-bottom: 14rpx;
}

.switch-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 14rpx;
  border-radius: 8rpx;
  margin-bottom: 6rpx;
  background: rgba(216, 207, 190, .12);
  transition: background .12s;
}

.switch-item.active {
  background: rgba(83, 125, 150, .12);
  border: 1rpx solid rgba(83, 125, 150, .32);
}

.switch-check {
  width: 32rpx;
  flex-shrink: 0;
  text-align: center;
  color: #537d96;
  font-size: 28rpx;
  font-weight: 900;
}

.switch-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  background: rgba(216, 207, 190, .45);
  color: #2a2622;
  font-size: 20rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.switch-info {
  flex: 1;
  min-width: 0;
}

.switch-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #2a2622;
}

.switch-model {
  font-size: 22rpx;
  color: #6b6158;
  margin-top: 2rpx;
}

/* ── 3. All providers list ── */
.section-head {
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2a2622;
}

.provider-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(216, 207, 190, .72);
}

.provider-item:last-child {
  border-bottom: 0;
}

.provider-item.active {
  background: rgba(83, 125, 150, .04);
  border-radius: 8rpx;
  margin: 0 -14rpx;
  padding: 20rpx 14rpx;
}

.pi-left {
  width: 52rpx;
  height: 52rpx;
  border-radius: 12rpx;
  background: rgba(216, 207, 190, .45);
  color: #2a2622;
  font-size: 22rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pi-mid {
  flex: 1;
  min-width: 0;
}

.pi-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pi-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #2a2622;
}

.pi-tag {
  display: inline-flex;
  align-items: center;
  height: 30rpx;
  padding: 0 10rpx;
  border-radius: 4rpx;
  background: rgba(83, 125, 150, .12);
  color: #537d96;
  font-size: 18rpx;
  font-weight: 800;
  flex-shrink: 0;
}

.pi-url {
  font-size: 22rpx;
  color: #6b6158;
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pi-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 4rpx;
}

.pi-model {
  font-size: 24rpx;
  color: #2a2622;
  font-weight: 800;
}

.key-badge {
  display: inline-flex;
  align-items: center;
  height: 30rpx;
  padding: 0 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.key-badge.ready {
  background: rgba(34, 197, 94, .10);
  color: #16a34a;
}

.key-badge.empty {
  background: rgba(168, 162, 158, .12);
  color: #78716c;
}

.pi-right {
  flex-shrink: 0;
}

.pi-edit {
  margin: 0;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: rgba(216, 207, 190, .28);
  color: #2a2622;
  font-size: 24rpx;
  font-weight: 800;
  border: 1rpx solid rgba(216, 207, 190, .72);
}

.pi-edit::after {
  border: 0;
}

.add-provider-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 24rpx 0 8rpx;
  border-top: 1rpx solid rgba(216, 207, 190, .72);
  margin-top: 8rpx;
}

.add-icon {
  font-size: 28rpx;
  color: #537d96;
  font-weight: 900;
}

.add-text {
  font-size: 26rpx;
  color: #537d96;
  font-weight: 800;
}

/* ── 4. Editor panel ── */
.editor-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.editor-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2a2622;
}

.editor-close {
  font-size: 34rpx;
  color: #6b6158;
  padding: 8rpx 12rpx;
  line-height: 1;
}

.form-group {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(216, 207, 190, .72);
}

.form-group:last-child {
  border-bottom: 0;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #2a2622;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.form-input {
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
  background: rgba(216, 207, 190, .20);
  border: 1rpx solid rgba(216, 207, 190, .72);
  border-radius: 6rpx;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #2a2622;
}

.form-input.password {
  font-family: monospace;
  letter-spacing: 0;
}

.form-textarea {
  width: 100%;
  min-height: 92rpx;
  box-sizing: border-box;
  background: rgba(216, 207, 190, .20);
  border: 1rpx solid rgba(216, 207, 190, .72);
  border-radius: 6rpx;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #2a2622;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.form-grid .form-group {
  border-bottom: 0;
  padding: 18rpx 0;
}

.key-row {
  margin-bottom: 8rpx;
}

.key-input {
  font-family: monospace;
  letter-spacing: 0;
}

.key-hint {
  font-size: 22rpx;
  color: #6b6158;
  margin-bottom: 8rpx;
}

.key-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 10rpx;
}

.key-btn {
  flex: 1;
  margin: 0;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  border-radius: 6rpx;
  background: rgba(216, 207, 190, .28);
  border: 1rpx solid rgba(216, 207, 190, .72);
  color: #2a2622;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.key-btn::after {
  border: 0;
}

.fetch-btn {
  margin: 0;
  width: 100%;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 8rpx;
  background: #537d96;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

.fetch-btn::after {
  border: 0;
}

.fetch-btn.loading,
.fetch-btn[disabled] {
  opacity: .65;
  color: #fff;
}

.editor-actions {
  display: grid;
  grid-template-columns: 1fr 1.45fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.editor-action {
  margin: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border-radius: 8rpx;
  background: rgba(216, 207, 190, .30);
  color: #2a2622;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
}

.editor-action::after {
  border: 0;
}

.editor-action.primary {
  background: #537d96;
  color: #fff;
}

.delete-row {
  padding: 20rpx 0 4rpx;
  text-align: center;
}

.delete-text {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 800;
}

/* ── 5. Advanced settings ── */
.adv-head {
  cursor: pointer;
}

.adv-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.adv-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #2a2622;
}

.adv-arrow {
  font-size: 38rpx;
  color: #a8a29e;
  line-height: 1;
  transition: transform .2s;
}

.adv-arrow.open {
  transform: rotate(90deg);
}

.adv-summary {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #6b6158;
}

.label-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.label-line .form-label {
  margin-bottom: 0;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  box-sizing: border-box;
  background: rgba(216, 207, 190, .20);
  border: 1rpx solid rgba(216, 207, 190, .72);
  border-radius: 6rpx;
  padding: 16rpx 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #2a2622;
}

.picker-arrow {
  color: #a8a29e;
  font-size: 32rpx;
}

.field-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #6b6158;
}

/* Catalog stats (reused from original) */
.catalog-stats {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin: 8rpx 0 16rpx;
}

.catalog-stat {
  min-width: 0;
  padding: 16rpx 8rpx;
  background: rgba(216, 207, 190, .25);
  border: 1rpx solid rgba(216, 207, 190, .72);
  border-radius: 8rpx;
  text-align: center;
}

.catalog-stat.danger {
  background: rgba(255, 45, 98, .08);
  border-color: rgba(255, 45, 98, .24);
}

.stat-num {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #2a2622;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.3;
  color: #6b6158;
}

.skill-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.skill-card {
  padding: 18rpx;
  background: rgba(255, 253, 247, .58);
  border: 1rpx solid rgba(216, 207, 190, .78);
  border-radius: 8rpx;
}

.skill-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.skill-title {
  min-width: 0;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 900;
  color: #2a2622;
}

.skill-badges {
  flex-shrink: 0;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
  max-width: 320rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 6rpx;
  background: rgba(83, 125, 150, .12);
  color: #537d96;
  font-size: 22rpx;
  font-weight: 800;
}

.badge.warn {
  background: rgba(177, 117, 44, .12);
  color: #9a651f;
}

.badge.danger {
  background: rgba(255, 45, 98, .10);
  color: #c92554;
}

.skill-actions {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: #6b6158;
  word-break: break-all;
}

.action-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 8rpx;
}

.action-chip {
  max-width: 100%;
  box-sizing: border-box;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  background: rgba(83, 125, 150, .10);
  color: #537d96;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 800;
}

.action-chip.medium {
  background: rgba(177, 117, 44, .12);
  color: #9a651f;
}

.action-chip.high {
  background: rgba(255, 45, 98, .10);
  color: #c92554;
}

/* Responsive */
@media (max-width: 360px) {
  .form-grid {
    grid-template-columns: 1fr;
    gap: 0;
  }
}
