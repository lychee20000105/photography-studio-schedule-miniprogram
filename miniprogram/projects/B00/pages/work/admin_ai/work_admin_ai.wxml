<view class="page ai-config-page">
	<view wx:if="{{!isLoad}}" class="empty">加载中...</view>

	<view wx:if="{{isLoad}}">
		<view class="block">
			<view class="head">
				<view>
					<view class="title">AI 小助手配置</view>
					<view class="desc">猫咪对话会通过云函数代理调用，不会把 API Key 放进小程序前端。</view>
				</view>
				<switch checked="{{form.enabled}}" color="#537d96" bindchange="bindEnabledChange" />
			</view>
		</view>

		<view class="block">
			<view class="section-head">
				<view>
					<view class="section-title">供应商</view>
					<view class="desc compact">选择一套接口作为当前小猫默认配置，点编辑可改 Base URL、模型和 Key。</view>
				</view>
				<button class="icon-btn add-btn" bindtap="bindProviderAddTap">＋</button>
			</view>

			<view class="provider-list">
				<view wx:for="{{providerCards}}" wx:key="id" class="provider-card {{item.active?'active':''}}">
					<view class="drag-dot">⋮⋮</view>
					<view class="provider-avatar">{{item.initials}}</view>
					<view class="provider-main">
						<view class="provider-top">
							<view class="provider-name">{{item.name}}</view>
							<text wx:if="{{item.active}}" class="provider-tag active">当前默认</text>
							<text wx:if="{{!item.keyReady}}" class="provider-tag">待保存 Key</text>
						</view>
						<view class="provider-url">{{item.apiUrl}}</view>
						<view class="provider-meta">
							<text>{{item.modelText}}</text>
							<text>{{item.keyText}}</text>
						</view>
					</view>
					<view class="provider-actions">
						<button class="provider-action" data-index="{{index}}" bindtap="bindProviderEditTap">编辑</button>
						<button class="provider-action primary" data-index="{{index}}" bindtap="bindProviderUseTap">启用</button>
					</view>
				</view>
			</view>

			<view wx:if="{{providerEditorOpen}}" class="provider-editor">
				<view class="editor-head">
					<view class="editor-title">{{providerEditIndex>=0?'编辑供应商':'新增供应商'}}</view>
					<button class="editor-close" bindtap="bindProviderEditorCancelTap">×</button>
				</view>
				<view class="editor-grid">
					<view class="form-group">
						<view class="label">供应商名称</view>
						<input value="{{providerEditForm.name}}" data-field="name" bindinput="bindProviderEditInput" placeholder="例如 Mimo / DeepSeek / blueroy.site" />
					</view>
					<view class="form-group">
						<view class="label">备注</view>
						<input value="{{providerEditForm.remark}}" data-field="remark" bindinput="bindProviderEditInput" placeholder="例如：公司专用账号" />
					</view>
				</view>
				<view class="form-group">
					<view class="label">官网链接</view>
					<input value="{{providerEditForm.website}}" data-field="website" bindinput="bindProviderEditInput" placeholder="https://platform.example.com" />
				</view>
				<view class="form-group">
					<view class="label-line">
						<view class="label">API 请求地址</view>
						<text class="inline-hint">OpenAI 兼容 /v1 地址</text>
					</view>
					<textarea value="{{providerEditForm.apiUrl}}" data-field="apiUrl" bindinput="bindProviderEditInput" maxlength="400" auto-height="{{true}}" placeholder="https://api.example.com/v1"></textarea>
				</view>
				<view class="form-group">
					<view class="label">API Key</view>
					<view class="key-editor">
						<input class="key-input" password="{{!providerEditKeyVisible}}" value="{{providerEditForm.apiKey}}" data-field="apiKey" bindinput="bindProviderEditInput" maxlength="400" confirm-type="done" adjust-position="{{true}}" cursor-spacing="96" placeholder="{{keyPlaceholder}}" />
						<view class="key-actions">
							<button class="key-action primary" bindtap="bindProviderEditorPasteKeyTap">粘贴</button>
							<button class="key-action" bindtap="bindProviderEditorToggleKeyTap">{{providerEditKeyVisible?'隐藏':'显示'}}</button>
							<button class="key-action" bindtap="bindProviderEditorClearKeyTap">清空</button>
						</view>
					</view>
					<view class="key-state">留空则不修改当前已保存 Key；填写后点“应用到当前配置”，再点页面底部“保存配置”。</view>
					<view wx:if="{{hasApiKey}}" class="clear-line">
						<text>清空当前已保存主 Key</text>
						<switch checked="{{clearKey}}" color="#537d96" bindchange="bindClearKeyChange" />
					</view>
				</view>
				<view class="editor-grid">
					<view class="form-group">
						<view class="label">文本模型 ID</view>
						<input value="{{providerEditForm.model}}" data-field="model" bindinput="bindProviderEditInput" placeholder="mimo-v2.5 / deepseek-chat" />
					</view>
					<view class="form-group">
						<view class="label">视觉模型 ID（可选）</view>
						<input value="{{providerEditForm.visionModel}}" data-field="visionModel" bindinput="bindProviderEditInput" placeholder="留空沿用文本模型" />
					</view>
				</view>
				<view class="form-group">
					<view class="label">视觉接口地址（可选）</view>
					<input value="{{providerEditForm.visionApiUrl}}" data-field="visionApiUrl" bindinput="bindProviderEditInput" placeholder="留空沿用主 API 请求地址" />
				</view>
				<view class="editor-actions">
					<button class="editor-action" bindtap="bindProviderEditorCancelTap">取消</button>
					<button class="editor-action primary" bindtap="bindProviderEditorApplyTap">应用到当前配置</button>
				</view>
			</view>
		</view>

		<view class="block">
			<view class="section-title">文本模型</view>
			<view class="form-group">
				<view class="label-line">
					<view class="label">模型 ID</view>
					<button class="fetch-btn" loading="{{modelLoading && modelLoadingTarget=='text'}}" disabled="{{modelLoading}}" data-target="text" bindtap="bindLoadModelsTap">{{modelLoading && modelLoadingTarget=='text'?'获取中':'获取列表'}}</button>
				</view>
				<picker wx:if="{{textModelOptions.length}}" mode="selector" range="{{textModelOptions}}" value="{{textModelIndex}}" data-target="text" bindchange="bindModelChange">
					<view class="model-picker">
						<text>{{textModelPickerText}}</text>
						<text class="arrow">›</text>
					</view>
				</picker>
				<input value="{{form.model}}" data-field="model" bindinput="bindInput" placeholder="deepseek-chat / gpt-4o-mini / mimo 等模型 ID" />
				<view class="key-state">普通文字聊天、查询、录单默认使用这个模型。无需等模型列表，知道模型 ID 就能直接填写。</view>
				<view class="key-state">预估上下文：{{form.contextLimit || 128000}} tokens（按模型名估算）</view>
			</view>
		</view>

		<view class="block">
			<view class="section-title">图片识别模型</view>
			<view class="desc compact">聊天带图片时优先用这里的视觉模型；视觉地址和视觉 Key 留空时，会沿用上面的接口地址和 Key。</view>
			<view class="form-group">
				<view class="label">视觉接口地址（可选）</view>
				<textarea value="{{form.visionApiUrl}}" data-field="visionApiUrl" bindinput="bindInput" maxlength="400" auto-height="{{true}}" placeholder="留空沿用主 Base URL"></textarea>
			</view>
			<view class="form-group">
				<view class="label-line">
					<view class="label">视觉模型 ID</view>
					<button class="fetch-btn" loading="{{modelLoading && modelLoadingTarget=='vision'}}" disabled="{{modelLoading}}" data-target="vision" bindtap="bindLoadModelsTap">{{modelLoading && modelLoadingTarget=='vision'?'获取中':'获取列表'}}</button>
				</view>
				<picker wx:if="{{visionModelOptions.length}}" mode="selector" range="{{visionModelOptions}}" value="{{visionModelIndex}}" data-target="vision" bindchange="bindModelChange">
					<view class="model-picker">
						<text>{{visionModelPickerText}}</text>
						<text class="arrow">›</text>
					</view>
				</picker>
				<input value="{{form.visionModel}}" data-field="visionModel" bindinput="bindInput" placeholder="例如 gpt-4o-mini / qwen-vl-plus；留空沿用文本模型" />
				<view class="key-state">DeepSeek 等纯文本模型不一定能读图；要读图就填一个支持图片的兼容模型。</view>
				<view class="key-state">预估上下文：{{form.visionContextLimit || form.contextLimit || 128000}} tokens</view>
			</view>
			<view class="form-group">
				<view class="label">视觉 API Key（可选）</view>
				<view class="key-editor">
					<input class="key-input" password="{{!showVisionKeyInput}}" value="{{visionKeyInput}}" bindinput="bindVisionKeyInput" maxlength="400" confirm-type="done" adjust-position="{{true}}" cursor-spacing="96" placeholder="{{visionKeyPlaceholder}}" />
					<view class="key-actions">
						<button class="key-action primary" bindtap="bindPasteVisionKeyTap">粘贴</button>
						<button class="key-action" bindtap="bindToggleVisionKeyVisibleTap">{{showVisionKeyInput?'隐藏':'显示'}}</button>
						<button class="key-action" bindtap="bindClearVisionKeyInputTap">清空</button>
					</view>
				</view>
				<view wx:if="{{hasVisionApiKey}}" class="key-state">当前已保存：{{visionApiKeyMasked}}</view>
				<view wx:if="{{hasVisionApiKey}}" class="clear-line">
					<text>清空视觉 Key</text>
					<switch checked="{{clearVisionKey}}" color="#537d96" bindchange="bindClearVisionKeyChange" />
				</view>
			</view>
		</view>

		<view class="block">
			<view class="section-title">小猫行为</view>
			<view class="form-group">
				<view class="label">小猫性格</view>
				<picker mode="selector" range="{{form.personalities}}" range-key="name" value="{{personalityIndex}}" bindchange="bindPersonalityChange">
					<view class="model-picker">
						<text>{{form.personalityName || '值班小猫'}}</text>
						<text class="arrow">›</text>
					</view>
				</picker>
				<view class="key-state">值班适合日常录单，温柔适合新员工和话术，审查适合财务/审核边界，成交适合客户跟进。</view>
			</view>
			<view class="two-cols">
				<view class="mini-field">
					<view class="label">温度</view>
					<input type="digit" value="{{form.temperature}}" data-field="temperature" bindinput="bindInput" placeholder="0-2" />
				</view>
				<view class="mini-field">
					<view class="label">最大回复</view>
					<input type="number" value="{{form.maxTokens}}" data-field="maxTokens" bindinput="bindInput" placeholder="600" />
				</view>
			</view>
			<view class="form-group">
				<view class="label">系统提示词</view>
				<textarea value="{{form.systemPrompt}}" data-field="systemPrompt" bindinput="bindInput" maxlength="3000" auto-height="{{true}}" placeholder="告诉 AI 它是谁、怎么回答、不能做什么"></textarea>
			</view>
			<view class="form-group">
				<view class="label-line">
					<view class="label">长期记忆</view>
					<switch checked="{{form.memoryEnabled}}" color="#537d96" bindchange="bindMemoryEnabledChange" />
				</view>
				<textarea value="{{form.memoryText}}" data-field="memoryText" bindinput="bindInput" maxlength="2000" auto-height="{{true}}" placeholder="只写稳定规则：店内偏好、报价口径、客户跟进原则、团队默认习惯。不要写 API Key、手机号、客户隐私或一次性聊天内容。"></textarea>
				<view class="key-state">开启后，小猫会把这段作为管理员维护的店内规则参考；真实订单、金额、收款、工资和审核仍以后台数据为准。</view>
			</view>
		</view>

		<view class="block">
			<view class="section-title">Agent 能力边界</view>
			<view class="desc compact">这里只展示小猫当前内置的业务技能和受控动作；真正写入仍由后台按员工权限、字段完整度和审计规则校验。</view>
			<view class="catalog-stats">
				<view class="catalog-stat">
					<view class="stat-num">{{form.agentCatalog.stats.skillCount || 0}}</view>
					<view class="stat-label">技能</view>
				</view>
				<view class="catalog-stat">
					<view class="stat-num">{{form.agentCatalog.stats.actionCount || 0}}</view>
					<view class="stat-label">动作</view>
				</view>
				<view class="catalog-stat">
					<view class="stat-num">{{form.agentCatalog.stats.writeActionCount || 0}}</view>
					<view class="stat-label">写入</view>
				</view>
				<view class="catalog-stat danger">
					<view class="stat-num">{{form.agentCatalog.stats.highRiskActionCount || 0}}</view>
					<view class="stat-label">高风险</view>
				</view>
			</view>
			<view class="skill-list">
				<view wx:for="{{form.agentCatalog.skills}}" wx:key="key" class="skill-card">
					<view class="skill-head">
						<view class="skill-title">{{item.title}}</view>
						<view class="skill-badges">
							<text wx:if="{{item.image}}" class="badge">图片</text>
							<text wx:if="{{item.writeCount}}" class="badge warn">写入 {{item.writeCount}}</text>
							<text wx:if="{{item.highRiskCount}}" class="badge danger">高风险 {{item.highRiskCount}}</text>
						</view>
					</view>
					<view class="skill-actions">{{item.actionTitleText}}</view>
				</view>
			</view>
			<view class="action-list">
				<view wx:for="{{form.agentCatalog.actions}}" wx:key="key" class="action-chip {{item.riskLevel}}">
					<text>{{item.title}}</text>
				</view>
			</view>
		</view>

		<button class="submit" bindtap="bindSubmitTap">保存配置</button>
		<button class="submit plain" bindtap="bindTestTap">测试对话</button>
	</view>
</view>

<tech-footer />
