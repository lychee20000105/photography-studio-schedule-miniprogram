page {
	background: #f6f7f9;
}

.page {
	padding: 24rpx;
}

.block {
	background: #fff;
	border-radius: 10rpx;
	padding: 24rpx;
	margin-bottom: 18rpx;
	box-sizing: border-box;
}

.title {
	margin-bottom: 12rpx;
	color: #202735;
	font-size: 32rpx;
	font-weight: 800;
	line-height: 1.35;
}

.row {
	min-height: 82rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	border-bottom: 1rpx solid #edf0f4;
	color: #303846;
	font-size: 28rpx;
}

.row input {
	flex: 1;
	margin-left: 24rpx;
	text-align: right;
	color: #202735;
	font-size: 27rpx;
}

.primary {
	margin-top: 26rpx;
	height: 80rpx;
	line-height: 80rpx;
	border-radius: 10rpx;
	background: #ff2d62;
	color: #fff;
	font-size: 29rpx;
	font-weight: 800;
}

.guest {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 18rpx;
	background: #111827;
	color: #fff;
}

.guest-title {
	font-size: 30rpx;
	font-weight: 900;
	line-height: 1.35;
}

.guest-desc {
	margin-top: 8rpx;
	color: rgba(255, 255, 255, .72);
	font-size: 24rpx;
	line-height: 1.45;
}

.guest-btn {
	margin-top: 18rpx;
	height: 78rpx;
	line-height: 78rpx;
	border-radius: 10rpx;
	background: #111827;
	color: #fff;
	font-size: 28rpx;
	font-weight: 800;
}

.plain-btn {
	flex-shrink: 0;
	width: 164rpx;
	height: 64rpx;
	line-height: 64rpx;
	border-radius: 32rpx;
	background: #fff;
	color: #111827;
	font-size: 24rpx;
	font-weight: 800;
	padding: 0;
}

.profile {
	display: flex;
	align-items: center;
	text-align: left;
}

.pet-panel {
	padding: 24rpx;
	background: linear-gradient(135deg, #fff, #f7f9ff);
}

.pet-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 20rpx;
}

.pet-title {
	color: #111827;
	font-size: 31rpx;
	font-weight: 900;
	line-height: 1.35;
}

.pet-desc {
	margin-top: 6rpx;
	color: #7b8492;
	font-size: 24rpx;
	line-height: 1.4;
}

.pet-bars {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 18rpx;
	margin-top: 22rpx;
}

.pet-bar-label {
	color: #6b7280;
	font-size: 23rpx;
	line-height: 1.35;
	margin-bottom: 8rpx;
}

.pet-bar-track {
	height: 12rpx;
	border-radius: 8rpx;
	background: #e9edf3;
	overflow: hidden;
}

.pet-bar-fill {
	height: 100%;
	border-radius: 8rpx;
	transition: width .25s ease-out;
}

.pet-bar-fill.hunger {
	background: #f59e0b;
}

.pet-bar-fill.health {
	background: #10b981;
}

.pet-picker {
	display: flex;
	align-items: center;
	justify-content: space-between;
	height: 74rpx;
	margin-top: 20rpx;
	padding: 0 18rpx;
	border-radius: 12rpx;
	background: #f1f4f8;
	color: #303846;
	font-size: 26rpx;
	font-weight: 700;
	box-sizing: border-box;
}

.pet-picker text {
	color: #a0a7b2;
	font-size: 34rpx;
	font-weight: 400;
}

.pet-actions {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 14rpx;
	margin-top: 18rpx;
}

.pet-actions view {
	height: 62rpx;
	line-height: 62rpx;
	border-radius: 31rpx;
	background: #111827;
	color: #fff;
	font-size: 25rpx;
	font-weight: 800;
	text-align: center;
	transition: transform .16s ease-out, opacity .16s ease-out;
}

.pet-actions view:active {
	transform: scale(.95);
	opacity: .84;
}

.avatar {
	flex: none;
	width: 92rpx;
	height: 92rpx;
	line-height: 92rpx;
	border-radius: 46rpx;
	background: #111827;
	color: #fff;
	font-size: 40rpx;
	font-weight: 900;
	text-align: center;
}

.profile-main {
	flex: 1;
	min-width: 0;
	margin-left: 22rpx;
}

.name {
	color: #202735;
	font-size: 34rpx;
	font-weight: 900;
	line-height: 1.25;
}

.mobile {
	color: #858d99;
	font-size: 25rpx;
	line-height: 1.4;
	margin-top: 6rpx;
}

.roles {
	display: flex;
	flex-wrap: wrap;
	gap: 10rpx;
	margin-top: 14rpx;
}

.roles text {
	background: #f1f4f8;
	border-radius: 6rpx;
	padding: 6rpx 12rpx;
	color: #596273;
	font-size: 23rpx;
	line-height: 1.25;
}

.menu {
	padding: 0 24rpx;
}

.item {
	min-height: 86rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	border-bottom: 1rpx solid #edf0f4;
	color: #202735;
	font-size: 28rpx;
	font-weight: 700;
}

.item:last-child {
	border-bottom: 0;
}

.item-left {
	display: flex;
	align-items: center;
	min-width: 0;
}

.item-left [class*=icon] {
	width: 42rpx;
	margin-right: 16rpx;
	color: #6f7a8a;
	font-size: 32rpx;
	text-align: center;
}

.unread-badge {
	min-width: 34rpx;
	height: 34rpx;
	line-height: 34rpx;
	margin-left: 14rpx;
	padding: 0 9rpx;
	border-radius: 18rpx;
	background: #ef4444;
	color: #fff;
	font-size: 20rpx;
	font-weight: 900;
	text-align: center;
	box-sizing: border-box;
}

.version-chip {
	margin-left: 14rpx;
	padding: 5rpx 12rpx;
	border-radius: 999rpx;
	background: #eef6f8;
	color: #3f6179;
	font-size: 21rpx;
	font-weight: 900;
}

.arrow {
	margin-left: 18rpx;
	color: #b5bbc5;
	font-size: 34rpx;
	font-weight: 400;
	line-height: 1;
}

/* ===== Warm paper overrides (亮色模式) ===== */
page {
	background-color: var(--color-bg);
	background-image:
		linear-gradient(90deg, rgba(122, 96, 68, .035) 1rpx, transparent 1rpx),
		linear-gradient(180deg, rgba(255, 253, 247, .56), rgba(216, 207, 190, .22));
	background-size: 48rpx 48rpx, 100% 100%;
	color: #2a2622;
}

/* 暗黑模式下页面文字色 */
page.dark {
	color: var(--color-text-primary);
	background-image: none;
}

.page {
	padding-bottom: 150rpx;
}

.block,
.pet-panel {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 12rpx 38rpx rgba(42, 38, 34, .06);
	border-radius: 10rpx;
}

.guest {
	color: #2a2622;
}

.guest-desc,
.mobile,
.pet-desc,
.pet-bar-label,
.row,
.roles text,
.item-left [class*=icon],
.arrow {
	color: #6b6158;
}

.title,
.name,
.pet-title,
.row input,
.item {
	color: #2a2622;
}

.primary,
.guest-btn,
.pet-actions view {
	background: var(--color-brand);
	color: #fff;
}

.plain-btn {
	background: #fbf7ee;
	color: var(--color-brand);
	border: 1rpx solid #d8cfbe;
}

.avatar {
	background: #fbf7ee;
	color: var(--color-brand);
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 8rpx 22rpx rgba(42, 38, 34, .05);
}

.row,
.item {
	border-bottom-color: rgba(216, 207, 190, .72);
}

.roles text,
.pet-picker,
.pet-bar-track,
.version-chip {
	background: rgba(216, 207, 190, .28);
}

.pet-bar-fill.hunger {
	background: #b7791f;
}

.pet-bar-fill.health {
	background: #4a6b4a;
}

.pet-picker {
	color: #2a2622;
	border: 1rpx solid rgba(216, 207, 190, .72);
}

/* ===== B17: 暗黑模式覆盖 ===== */
page.dark {
	background-color: var(--color-bg);
	background-image: none;
}

page.dark .block,
page.dark .pet-panel {
	background: var(--color-bg-card);
	border-color: var(--color-border);
	box-shadow: 0 12rpx 38rpx var(--color-shadow);
}

page.dark .guest {
	color: var(--color-text-primary);
}

page.dark .guest-desc,
page.dark .mobile,
page.dark .pet-desc,
page.dark .pet-bar-label,
page.dark .row,
page.dark .roles text,
page.dark .item-left [class*=icon],
page.dark .arrow {
	color: var(--color-text-secondary);
}

page.dark .title,
page.dark .name,
page.dark .pet-title,
page.dark .row input,
page.dark .item {
	color: var(--color-text-primary);
}

page.dark .primary,
page.dark .guest-btn,
page.dark .pet-actions view {
	background: var(--color-brand);
	color: #fff;
}

page.dark .plain-btn {
	background: var(--color-bg-card);
	color: var(--color-brand);
	border-color: var(--color-border);
}

page.dark .avatar {
	background: var(--color-bg-card);
	color: var(--color-brand);
	border-color: var(--color-border);
	box-shadow: 0 8rpx 22rpx var(--color-shadow);
}

page.dark .row,
page.dark .item {
	border-bottom-color: var(--color-border);
}

page.dark .roles text,
page.dark .pet-picker,
page.dark .pet-bar-track,
page.dark .version-chip {
	background: var(--color-bg-input);
}

page.dark .pet-picker {
	color: var(--color-text-primary);
	border-color: var(--color-border);
}

page.dark .pet-panel {
	background: var(--color-bg-card);
}
