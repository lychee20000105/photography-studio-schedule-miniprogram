<wxs src="../../../../helper/filters.wxs" module="f" />
<view class="page">
	<view class="section">订单完成审核</view>
	<view wx:if="{{orders.length==0}}" class="empty">暂无待审核订单</view>
	<view wx:for="{{orders}}" wx:key="_id" wx:for-index="oi" class="card">
		<view class="title">{{item.ORDER_TYPE_NAME}}｜{{item.ORDER_CUSTOMER_NAME}}</view>
		<view class="meta">{{f.fmtDate(item.ORDER_DATE)}} {{item.ORDER_TIME}} · {{item.ORDER_SETTLE_STATUS_DESC}}</view>
		<view class="pay">实收：{{f.fmtMoney(item.ORDER_ACTUAL_AMOUNT)}} ｜ {{item.paymentText}}</view>
		<view class="actions"><button class="reject" bindtap="bindRejectTap" data-idx="{{oi}}">驳回</button><button class="pass" bindtap="bindPassTap" data-idx="{{oi}}">通过并释放</button></view>
	</view>
</view>

<tech-footer />
<work-pet id="workPet" />