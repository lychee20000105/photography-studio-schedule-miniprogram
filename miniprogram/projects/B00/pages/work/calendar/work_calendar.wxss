page {
	background: #f6f7f9;
	color: #111827;
}

.work-page {
	padding: 28rpx 24rpx 140rpx;
	box-sizing: border-box;
	width: 100%;
	max-width: 1180rpx;
	margin: 0 auto;
}

.guest-banner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 18rpx;
	margin-bottom: 22rpx;
	padding: 22rpx 24rpx;
	border-radius: 14rpx;
	background: #111827;
	color: #fff;
	box-sizing: border-box;
}

.guest-title {
	font-size: 29rpx;
	font-weight: 900;
	line-height: 1.3;
}

.guest-desc {
	margin-top: 6rpx;
	color: rgba(255, 255, 255, .72);
	font-size: 23rpx;
	line-height: 1.4;
}

.guest-action {
	flex-shrink: 0;
	min-width: 132rpx;
	height: 56rpx;
	line-height: 56rpx;
	text-align: center;
	border-radius: 28rpx;
	background: #ff2d62;
	color: #fff;
	font-size: 24rpx;
	font-weight: 800;
}

.topbar {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 24rpx;
	gap: 20rpx;
}

.avatar {
	width: 72rpx;
	height: 72rpx;
	border-radius: 50%;
	background: #111827;
	color: #fff;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 30rpx;
	font-weight: 700;
}

.seg {
	display: flex;
	background: #eceff3;
	border-radius: 12rpx;
	padding: 6rpx;
	flex-shrink: 0;
	min-width: 0;
}

.seg-item {
	min-width: 112rpx;
	min-height: 62rpx;
	line-height: 62rpx;
	text-align: center;
	border-radius: 10rpx;
	font-weight: 700;
	color: #4b5563;
	box-sizing: border-box;
	font-size: 24rpx;
	padding: 0 12rpx;
}

.seg-item.active {
	background: #ff2d62;
	color: #fff;
}

.monthbar {
	display: flex;
	align-items: center;
	justify-content: center;
	margin: 8rpx 0 24rpx;
}

.month-title {
	flex: 1;
	min-width: 0;
	text-align: center;
	font-size: 48rpx;
	font-weight: 800;
	margin: 0 18rpx;
	letter-spacing: 0;
	line-height: 1.2;
}

.today-btn {
	flex-shrink: 0;
	height: 54rpx;
	line-height: 54rpx;
	padding: 0 20rpx;
	border-radius: 27rpx;
	background: #111827;
	color: #fff;
	font-size: 24rpx;
	font-weight: 800;
	margin-right: 14rpx;
	box-sizing: border-box;
}

.month-btn {
	width: 66rpx;
	height: 66rpx;
	line-height: 60rpx;
	text-align: center;
	border-radius: 10rpx;
	background: #eef0f4;
	font-size: 48rpx;
	color: #253040;
	flex-shrink: 0;
	box-sizing: border-box;
}

.week,
.calendar {
	display: grid;
	grid-template-columns: repeat(7, 1fr);
}

.calendar-viewport {
	height: 760rpx;
	overflow: hidden;
	touch-action: pan-y;
}

.calendar-track {
	display: flex;
	height: 760rpx;
	will-change: transform;
}

.calendar-panel {
	flex: none;
	height: 760rpx;
	box-sizing: border-box;
}

.week view {
	text-align: center;
	color: #8c8c8c;
	font-weight: 700;
	padding: 12rpx 0;
}

.week view:first-child,
.week view:last-child {
	color: #ff2d62;
}

.calendar {
	background: #fff;
	border-radius: 12rpx;
	overflow: hidden;
	border: 1rpx solid #edf0f3;
}

.day {
	min-height: 120rpx;
	padding: 12rpx 6rpx;
	border-right: 1rpx solid #f0f2f5;
	border-bottom: 1rpx solid #f0f2f5;
	box-sizing: border-box;
	overflow: hidden;
}

.day.muted {
	color: #c6cbd2;
	background: #fbfbfc;
}

.day.selected {
	background: #fff1f5;
	box-shadow: inset 0 0 0 2rpx rgba(255, 45, 98, .26);
}

.day.today .num {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	min-width: 48rpx;
	height: 48rpx;
	border-radius: 24rpx;
	background: #111827;
	color: #fff;
}

.num {
	font-size: 32rpx;
	font-weight: 800;
	line-height: 44rpx;
}

.lunar {
	font-size: 20rpx;
	color: #8b9099;
	height: 28rpx;
	line-height: 28rpx;
	overflow: hidden;
}

.tags {
	margin-top: 6rpx;
	display: flex;
	flex-direction: column;
	gap: 5rpx;
	min-width: 0;
}

.tag {
	height: 34rpx;
	line-height: 34rpx;
	border-radius: 7rpx;
	color: #fff;
	font-size: 20rpx;
	text-align: center;
	margin-top: 0;
	padding: 0 6rpx;
	box-sizing: border-box;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
}

.markers {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 6rpx;
	margin-top: 4rpx;
	height: 12rpx;
}

.marker-dot {
	width: 10rpx;
	height: 10rpx;
	border-radius: 50%;
}

.marker-order {
	background: #537d96;
}

.marker-appt {
	background: #6db389;
}

.section-title-row {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 18rpx;
	margin: 34rpx 0 18rpx;
}

.section-title {
	font-size: 34rpx;
	font-weight: 800;
	margin: 0;
	min-width: 0;
}

.inline-add {
	min-width: 108rpx;
	height: 58rpx;
	line-height: 58rpx;
	text-align: center;
	border-radius: 29rpx;
	background: #111827;
	color: #fff;
	font-size: 26rpx;
	font-weight: 800;
	flex-shrink: 0;
}

.empty {
	height: 140rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	color: #8b9099;
}

.order-card,
.simple-card {
	background: #fff;
	border-radius: 12rpx;
	padding: 26rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 8rpx 26rpx rgba(15, 23, 42, .05);
}

.order-head {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 16rpx;
}

.order-type {
	color: #fff;
	font-weight: 800;
	border-radius: 8rpx;
	padding: 10rpx 18rpx;
	font-size: 26rpx;
	max-width: 420rpx;
	overflow: hidden;
	white-space: nowrap;
	text-overflow: ellipsis;
	box-sizing: border-box;
}

.order-time {
	font-size: 32rpx;
	font-weight: 800;
	flex-shrink: 0;
}

.customer {
	font-size: 36rpx;
	font-weight: 800;
	margin-top: 22rpx;
	line-height: 1.25;
	word-break: break-all;
}

.money,
.meta,
.simple-desc {
	margin-top: 18rpx;
	color: #8b9099;
	font-size: 26rpx;
	line-height: 1.55;
	word-break: break-all;
}

.simple-title {
	font-size: 32rpx;
	font-weight: 800;
}

.rest {
	background: #fafafa;
}

/* ===== Warm paper overrides (亮色模式) ===== */
page {
	background-color: var(--color-bg);
	background-image:
		linear-gradient(90deg, rgba(122, 96, 68, .035) 1rpx, transparent 1rpx),
		linear-gradient(180deg, rgba(255, 253, 247, .56), rgba(216, 207, 190, .22));
	background-size: 48rpx 48rpx, 100% 100%;
	color: #2a2622;
}

/* 暗黑模式下页面文字色 */
page.dark {
	color: var(--color-text-primary);
	background-image: none;
}

.work-page {
	padding: 30rpx 24rpx 150rpx;
}

.guest-banner,
.calendar,
.order-card,
.simple-card {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 12rpx 38rpx rgba(42, 38, 34, .06);
}

.guest-banner {
	color: #2a2622;
	border-radius: 10rpx;
}

.guest-desc,
.lunar,
.money,
.meta,
.simple-desc,
.empty {
	color: #6b6158;
}

.guest-action,
.today-btn,
.inline-add {
	background: var(--color-brand);
	color: #fff;
	box-shadow: 0 8rpx 22rpx rgba(83, 125, 150, .18);
}

.avatar,
.month-btn {
	background: #fbf7ee;
	color: var(--color-brand);
	border: 1rpx solid #d8cfbe;
	box-shadow: 0 8rpx 22rpx rgba(42, 38, 34, .05);
}

.seg {
	background: rgba(216, 207, 190, .48);
	border: 1rpx solid rgba(216, 207, 190, .78);
	border-radius: 8rpx;
}

.seg-item {
	color: #6b6158;
	border-radius: 6rpx;
}

.seg-item.active,
.day.today .num {
	background: var(--color-brand);
	color: #fff;
}

.month-title,
.section-title,
.num,
.order-time,
.customer,
.simple-title {
	color: #2a2622;
}

.week {
	position: sticky;
	top: 0;
	z-index: 10;
	background: var(--color-bg);
}

.week view {
	color: #8f867b;
}

.week view:first-child,
.week view:last-child {
	color: #8b2c1f;
}

.calendar {
	border-radius: 16rpx;
}

.day {
	border-right: 1rpx solid rgba(216, 207, 190, .62);
	border-bottom: 1rpx solid rgba(216, 207, 190, .62);
	background: rgba(251, 247, 238, .72);
}

.day.muted {
	background: rgba(239, 232, 219, .7);
	color: #b8b0a3;
}

.day.selected {
	background: rgba(83, 125, 150, .15);
	box-shadow: inset 0 0 0 2rpx rgba(83, 125, 150, .45);
}

.tag,
.order-type {
	box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, .34);
}

.rest {
	background: #f4eadf;
}

/* ===== B17: 暗黑模式覆盖 ===== */
page.dark {
	background-color: var(--color-bg);
	background-image: none;
}

page.dark .guest-banner,
page.dark .calendar,
page.dark .order-card,
page.dark .simple-card {
	background: var(--color-bg-card);
	border-color: var(--color-border);
	box-shadow: 0 12rpx 38rpx var(--color-shadow);
}

page.dark .guest-banner {
	color: var(--color-text-primary);
}

page.dark .guest-desc,
page.dark .lunar,
page.dark .money,
page.dark .meta,
page.dark .simple-desc,
page.dark .empty {
	color: var(--color-text-secondary);
}

page.dark .guest-action,
page.dark .today-btn,
page.dark .inline-add {
	background: var(--color-brand);
	box-shadow: 0 8rpx 22rpx var(--color-shadow);
}

page.dark .avatar,
page.dark .month-btn {
	background: var(--color-bg-card);
	color: var(--color-brand);
	border-color: var(--color-border);
	box-shadow: 0 8rpx 22rpx var(--color-shadow);
}

page.dark .seg {
	background: var(--color-bg-input);
	border-color: var(--color-border);
}

page.dark .seg-item {
	color: var(--color-text-secondary);
}

page.dark .seg-item.active,
page.dark .day.today .num {
	background: var(--color-brand);
	color: #fff;
}

page.dark .month-title,
page.dark .section-title,
page.dark .num,
page.dark .order-time,
page.dark .customer,
page.dark .simple-title {
	color: var(--color-text-primary);
}

page.dark .week {
	background: var(--color-bg);
}

page.dark .week view {
	color: var(--color-text-secondary);
}

page.dark .week view:first-child,
page.dark .week view:last-child {
	color: var(--color-danger);
}

page.dark .calendar {
	border-color: var(--color-border);
}

page.dark .day {
	border-right-color: var(--color-border);
	border-bottom-color: var(--color-border);
	background: var(--color-bg-card);
}

page.dark .day.muted {
	background: var(--color-bg-input);
	color: var(--color-text-hint);
}

page.dark .day.selected {
	background: var(--color-brand-light);
	box-shadow: inset 0 0 0 2rpx rgba(111, 168, 199, .4);
}

page.dark .tag,
page.dark .order-type {
	box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, .12);
}

page.dark .rest {
	background: var(--color-bg-input);
}

page.dark .marker-order {
	background: var(--color-brand);
}

page.dark .marker-appt {
	background: var(--color-success);
}
