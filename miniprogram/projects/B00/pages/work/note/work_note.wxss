page { background: #f6f7f9; }
.page { padding: 24rpx 24rpx 140rpx; }
.guest-banner { margin-bottom: 20rpx; padding: 20rpx 22rpx; border-radius: 14rpx; background: #111827; color: #fff; font-size: 25rpx; line-height: 1.45; }
.seg { display: flex; background: #eceff3; border-radius: 12rpx; padding: 6rpx; margin-bottom: 24rpx; }
.seg view { flex: 1; height: 64rpx; line-height: 64rpx; text-align: center; font-weight: 800; border-radius: 10rpx; color: #4b5563; font-size: 25rpx; }
.seg .active { background: #ff2d62; color: #fff; }
.ai-section-tip { margin-bottom: 18rpx; padding: 18rpx 22rpx; border-radius: 12rpx; background: #eef6f8; color: #3f6179; font-size: 24rpx; line-height: 1.5; }
.card { background: #fff; border-radius: 12rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 8rpx 26rpx rgba(15,23,42,.05); }
.card.ai-card { opacity: .92; }
.head { display: flex; align-items: center; justify-content: space-between; }
.title { font-size: 34rpx; font-weight: 900; }
.tag { background: #111827; color: #fff; border-radius: 8rpx; padding: 8rpx 16rpx; font-size: 24rpx; }
.tag.ai-tag { background: #8b5cf6; }
.content { margin-top: 20rpx; color: #374151; font-size: 28rpx; line-height: 1.6; max-height: 136rpx; overflow: hidden; }
.ai-content { max-height: none; font-size: 25rpx; color: #6b6158; }
.agent-box { margin-top: 20rpx; padding: 18rpx 20rpx; border-radius: 12rpx; background: rgba(83, 125, 150, .08); }
.agent-title { margin-bottom: 12rpx; color: #3f6179; font-size: 24rpx; font-weight: 900; }
.agent-line { display: flex; align-items: flex-start; gap: 12rpx; margin-top: 10rpx; color: #374151; font-size: 27rpx; line-height: 1.55; }
.agent-line text { flex: 0 0 34rpx; color: #537d96; font-weight: 900; }
.agent-line view { flex: 1; min-width: 0; }
.meta { margin-top: 20rpx; color: #8b9099; font-size: 24rpx; }
.empty { height: 300rpx; display: flex; align-items: center; justify-content: center; color: #8b9099; }
.fab { position: fixed; right: 42rpx; bottom: 130rpx; width: 104rpx; height: 104rpx; line-height: 96rpx; text-align: center; border-radius: 52rpx; background: #ff2d62; color: #fff; font-size: 70rpx; box-shadow: 0 14rpx 34rpx rgba(255,45,98,.32); }

/* Warm paper overrides */
page { background: #f5efe4; background-image: linear-gradient(90deg, rgba(122,96,68,.035) 1rpx, transparent 1rpx), linear-gradient(180deg, rgba(255,253,247,.56), rgba(216,207,190,.22)); background-size: 48rpx 48rpx, 100% 100%; color: #2a2622; }
.page { padding-bottom: 150rpx; }
.guest-banner, .seg, .card, .ai-section-tip { background: #fbf7ee; border: 1rpx solid #d8cfbe; box-shadow: 0 12rpx 38rpx rgba(42,38,34,.06); }
.guest-banner { color: #2a2622; }
.seg { border-radius: 8rpx; }
.seg view { color: #6b6158; border-radius: 6rpx; }
.seg .active, .tag, .fab { background: #537d96; color: #fff; }
.tag.ai-tag { background: #8a6f4d; }
.card { border-radius: 10rpx; }
.title { color: #2a2622; }
.content, .agent-line { color: #4a433c; }
.agent-box { background: rgba(83,125,150,.08); border: 1rpx solid rgba(83,125,150,.12); }
.ai-section-tip, .agent-title, .agent-line text { color: #3f6179; }
.meta, .empty { color: #6b6158; }
.fab { box-shadow: 0 14rpx 34rpx rgba(83,125,150,.26); }
