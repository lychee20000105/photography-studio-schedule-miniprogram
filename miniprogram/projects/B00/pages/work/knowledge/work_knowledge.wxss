page { background: #f5efe4; background-image: linear-gradient(90deg, rgba(122,96,68,.035) 1rpx, transparent 1rpx), linear-gradient(180deg, rgba(255,253,247,.56), rgba(216,207,190,.22)); background-size: 48rpx 48rpx, 100% 100%; color: #2a2622; }
.page { padding: 24rpx 24rpx 150rpx; box-sizing: border-box; }
.guest-banner { margin-bottom: 18rpx; padding: 18rpx 20rpx; border-radius: 12rpx; background: rgba(83,125,150,.12); color: #537d96; font-size: 24rpx; line-height: 1.5; }
.head { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; padding: 26rpx; border-radius: 14rpx; background: #fbf7ee; border: 1rpx solid #d8cfbe; box-shadow: 0 12rpx 38rpx rgba(42,38,34,.06); }
.eyebrow { color: #537d96; font-size: 22rpx; font-weight: 900; }
.title { margin-top: 6rpx; color: #2a2622; font-size: 38rpx; font-weight: 900; line-height: 1.3; }
.sub { margin-top: 10rpx; color: #6b6158; font-size: 24rpx; line-height: 1.5; }
.admin-btn { flex: none; margin-top: 4rpx; padding: 14rpx 20rpx; border-radius: 999rpx; background: #537d96; color: #fff; font-size: 24rpx; font-weight: 900; }
.seg { display: flex; gap: 12rpx; margin: 22rpx 0; overflow-x: auto; }
.seg-item { flex: none; padding: 14rpx 22rpx; border-radius: 999rpx; background: rgba(255,255,255,.55); border: 1rpx solid #d8cfbe; color: #6b6158; font-size: 24rpx; font-weight: 800; }
.seg-item.cur { background: #537d96; border-color: #537d96; color: #fff; }
.card { margin-bottom: 18rpx; padding: 24rpx; border-radius: 14rpx; background: #fbf7ee; border: 1rpx solid #d8cfbe; box-shadow: 0 12rpx 36rpx rgba(42,38,34,.05); }
.card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.card-title { color: #2a2622; font-size: 31rpx; font-weight: 900; line-height: 1.35; }
.card-summary { margin-top: 10rpx; color: #6b6158; font-size: 25rpx; line-height: 1.55; }
.type { flex: none; padding: 8rpx 14rpx; border-radius: 999rpx; background: rgba(83,125,150,.12); color: #537d96; font-size: 22rpx; font-weight: 900; }
.meta { display: flex; gap: 12rpx; margin-top: 18rpx; }
.meta text { padding: 8rpx 14rpx; border-radius: 999rpx; background: rgba(216,207,190,.45); color: #6b6158; font-size: 22rpx; font-weight: 800; }
