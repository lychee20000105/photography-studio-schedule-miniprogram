page {
  background: #f5efe4;
  color: #2f2a25;
  min-height: 100vh;
}

.page {
  padding: 24rpx;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.back {
  width: 60rpx;
  height: 60rpx;
  line-height: 54rpx;
  border-radius: 50%;
  background: #fff;
  text-align: center;
  font-size: 52rpx;
  color: #537d96;
}

.title-wrap {
  flex: 1;
}

.title,
.subtitle {
  display: block;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
}

.subtitle {
  margin-top: 4rpx;
  color: #7e7568;
  font-size: 24rpx;
}

.coin-pill {
  background: #ffffff;
  color: #8a6b2e;
  border-radius: 999rpx;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
}

.offline-card,
.hero-card,
.care-card,
.task,
.game-card {
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(47, 42, 37, 0.05);
}

.offline-card {
  padding: 22rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid rgba(83, 125, 150, 0.18);
}

.offline-title,
.offline-text {
  display: block;
}

.offline-title {
  font-size: 28rpx;
  font-weight: 700;
}

.offline-text {
  margin-top: 8rpx;
  color: #71685e;
  font-size: 24rpx;
}

.hero-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.cat-face {
  width: 150rpx;
  height: 130rpx;
  position: relative;
  margin-right: 24rpx;
}

.cat-ear {
  position: absolute;
  top: 0;
  width: 48rpx;
  height: 48rpx;
  background: #f3c56d;
  border-radius: 10rpx;
  transform: rotate(45deg);
}

.cat-ear.left { left: 24rpx; }
.cat-ear.right { right: 24rpx; }

.cat-head {
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  bottom: 0;
  height: 112rpx;
  border-radius: 62rpx 62rpx 46rpx 46rpx;
  background: #f3c56d;
  box-shadow: inset 0 -10rpx 0 rgba(0,0,0,0.06);
}

.eye {
  position: absolute;
  top: 46rpx;
  width: 14rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #332920;
}

.eye:first-child { left: 42rpx; }
.eye:nth-child(2) { right: 42rpx; }

.nose {
  position: absolute;
  left: 61rpx;
  top: 72rpx;
  width: 14rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #332920;
}

.hero-info {
  flex: 1;
}

.pet-name,
.pet-career {
  display: block;
}

.pet-name {
  font-size: 34rpx;
  font-weight: 700;
}

.pet-career {
  color: #746b60;
  margin-top: 6rpx;
  font-size: 24rpx;
}

.level-row {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #537d96;
}

.exp-bar,
.stat-bar {
  overflow: hidden;
  background: #eee3d3;
  border-radius: 999rpx;
}

.exp-bar {
  height: 18rpx;
  margin-top: 8rpx;
}

.exp-fill,
.stat-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.25s ease;
}

.exp-fill { background: #537d96; }
.food { background: #d99b4a; }
.mood { background: #d7798f; }
.energy { background: #6c9fd8; }
.clean { background: #64ad8d; }

.care-card {
  padding: 26rpx;
  margin-bottom: 18rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
}

.score,
.fold {
  color: #537d96;
  font-size: 24rpx;
}

.stat-item {
  display: grid;
  grid-template-columns: 72rpx 1fr 54rpx;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.stat-bar {
  height: 16rpx;
}

.care-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.care-btn {
  background: #f1e6d7;
  border-radius: 16rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 26rpx;
}

.checkin {
  background: #537d96;
  color: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.task-head {
  padding: 0 2rpx;
}

.task-list {
  margin-bottom: 22rpx;
}

.task {
  padding: 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.task-title,
.task-reward {
  display: block;
}

.task-title {
  font-size: 26rpx;
  font-weight: 600;
}

.task-reward {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #81776d;
}

.claim {
  background: #537d96;
  color: #fff;
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
  font-size: 24rpx;
}

.task-state {
  color: #9b9186;
  font-size: 24rpx;
}

.games-title {
  display: block;
  margin: 6rpx 0 14rpx;
}

.game-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.game-card.care {
  border-left: 8rpx solid #d99b4a;
}

.game-card.tower {
  border-left: 8rpx solid #537d96;
}

.game-mark {
  width: 70rpx;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 18rpx;
  text-align: center;
  background: #f1e6d7;
  font-weight: 700;
  color: #58483a;
  margin-right: 18rpx;
}

.game-copy {
  flex: 1;
}

.game-name,
.game-desc {
  display: block;
}

.game-name {
  font-size: 30rpx;
  font-weight: 700;
}

.game-desc {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #81776d;
}

.arrow {
  color: #b6aa9d;
  font-size: 44rpx;
}

.float {
  position: fixed;
  left: 50%;
  top: 42%;
  transform: translate(-50%, -50%);
  background: rgba(47,42,37,0.82);
  color: #fff;
  border-radius: 999rpx;
  padding: 18rpx 30rpx;
  font-size: 28rpx;
  z-index: 30;
}
