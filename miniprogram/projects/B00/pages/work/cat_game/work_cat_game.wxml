<view class="page">
  <view class="topbar">
    <view class="back" bind:tap="onBackTap">‹</view>
    <view class="title-wrap">
      <text class="title">小猫小游戏</text>
      <text class="subtitle">养成 + 塔防</text>
    </view>
    <view class="coin-pill">{{gameState.coins || 0}} 金币</view>
  </view>

  <view class="offline-card" wx:if="{{showOfflineReward}}" bind:tap="onClaimOffline">
    <text class="offline-title">欢迎回来</text>
    <text class="offline-text">小猫离线看店 {{offlineReward.hours}} 小时，领取 +{{offlineReward.coins}} 金币 / +{{offlineReward.exp}} 经验</text>
  </view>

  <view class="hero-card" wx:if="{{gameState}}">
    <view class="cat-face">
      <view class="cat-ear left"></view>
      <view class="cat-ear right"></view>
      <view class="cat-head">
        <view class="eye"></view>
        <view class="eye"></view>
        <view class="nose"></view>
      </view>
    </view>
    <view class="hero-info">
      <text class="pet-name">{{petTypeInfo.label}}</text>
      <text class="pet-career">{{petTypeInfo.career}} · {{phaseInfo.label}}</text>
      <view class="level-row">
        <text>Lv.{{gameState.level}}</text>
        <text>{{gameState.exp}} / {{gameState.level * 45}}</text>
      </view>
      <view class="exp-bar"><view class="exp-fill" style="width: {{expPercent}}%"></view></view>
    </view>
  </view>

  <view class="care-card" wx:if="{{gameState}}">
    <view class="section-head">
      <text class="section-title">小猫店长状态</text>
      <text class="score">状态 {{careScore}}</text>
    </view>
    <view class="stat-list">
      <view class="stat-item">
        <text>饱腹</text>
        <view class="stat-bar"><view class="stat-fill food" style="width: {{gameState.care.hunger}}%"></view></view>
        <text>{{gameState.care.hunger}}</text>
      </view>
      <view class="stat-item">
        <text>心情</text>
        <view class="stat-bar"><view class="stat-fill mood" style="width: {{gameState.care.mood}}%"></view></view>
        <text>{{gameState.care.mood}}</text>
      </view>
      <view class="stat-item">
        <text>体力</text>
        <view class="stat-bar"><view class="stat-fill energy" style="width: {{gameState.care.energy}}%"></view></view>
        <text>{{gameState.care.energy}}</text>
      </view>
      <view class="stat-item">
        <text>清洁</text>
        <view class="stat-bar"><view class="stat-fill clean" style="width: {{gameState.care.clean}}%"></view></view>
        <text>{{gameState.care.clean}}</text>
      </view>
    </view>

    <view class="care-actions">
      <view class="care-btn" data-action="feed" bind:tap="onCareTap">喂食</view>
      <view class="care-btn" data-action="play" bind:tap="onCareTap">玩耍</view>
      <view class="care-btn" data-action="rest" bind:tap="onCareTap">休息</view>
      <view class="care-btn" data-action="clean" bind:tap="onCareTap">清洁</view>
    </view>
  </view>

  <view class="checkin" bind:tap="onCheckinTap">
    {{gameState.dailyCheckin ? '今日已签到' : '今日签到 +20金币 +5经验'}}
  </view>

  <view class="section-head task-head" bind:tap="onToggleDailyTasks">
    <text class="section-title">每日任务</text>
    <text class="fold">{{showDailyTasks ? '收起' : '展开'}}</text>
  </view>
  <view class="task-list" wx:if="{{showDailyTasks}}">
    <view class="task" wx:for="{{dailyTasks}}" wx:key="id">
      <view>
        <text class="task-title">{{item.desc}}</text>
        <text class="task-reward">+{{item.reward.coins}}金币 +{{item.reward.exp}}经验</text>
      </view>
      <view wx:if="{{item.done && !item.claimed}}" class="claim" data-id="{{item.id}}" bind:tap="onClaimTask">领取</view>
      <view wx:else class="task-state">{{item.claimed ? '已领' : '未完成'}}</view>
    </view>
  </view>

  <view class="section-title games-title">选择小游戏</view>
  <view class="game-list">
    <view class="game-card {{item.id}}" wx:for="{{gameTypes}}" wx:key="id" data-id="{{item.id}}" bind:tap="onGameTap">
      <view class="game-mark">{{item.id === 'care' ? '养' : '防'}}</view>
      <view class="game-copy">
        <text class="game-name">{{item.name}}</text>
        <text class="game-desc">{{item.desc}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="float" wx:if="{{floatShow}}">{{floatText}}</view>
</view>
