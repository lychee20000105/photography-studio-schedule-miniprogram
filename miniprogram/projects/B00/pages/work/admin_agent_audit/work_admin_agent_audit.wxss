page {
	background: #f5efe4;
	color: #2a2622;
}

.page {
	padding: 24rpx 24rpx 150rpx;
	box-sizing: border-box;
}

.filter {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	border-radius: 10rpx;
	padding: 20rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 12rpx 38rpx rgba(42, 38, 34, .06);
}

.filter-row {
	display: flex;
	align-items: center;
	gap: 14rpx;
}

.keyword {
	flex: 1;
	min-width: 0;
	height: 72rpx;
	box-sizing: border-box;
	background: rgba(216, 207, 190, .25);
	border: 1rpx solid rgba(216, 207, 190, .72);
	border-radius: 8rpx;
	padding: 0 18rpx;
	font-size: 26rpx;
}

.search-btn,
.reset-btn {
	margin: 0;
	height: 72rpx;
	line-height: 72rpx;
	border-radius: 8rpx;
	font-size: 24rpx;
	font-weight: 800;
}

.search-btn {
	width: 132rpx;
	background: #537d96;
	color: #fff;
}

.reset-btn {
	width: 112rpx;
	background: transparent;
	color: #537d96;
	border: 1rpx solid #537d96;
}

.search-btn::after,
.reset-btn::after {
	border: 0;
}

.seg-row {
	display: grid;
	grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 112rpx;
	gap: 14rpx;
	margin-top: 16rpx;
	align-items: center;
}

.select {
	height: 72rpx;
	line-height: 72rpx;
	box-sizing: border-box;
	background: rgba(216, 207, 190, .25);
	border: 1rpx solid rgba(216, 207, 190, .72);
	border-radius: 8rpx;
	padding: 0 18rpx;
	font-size: 24rpx;
	font-weight: 800;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
}

.stats-panel {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	border-radius: 10rpx;
	padding: 20rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 12rpx 38rpx rgba(42, 38, 34, .06);
}

.stat-grid {
	display: grid;
	grid-template-columns: repeat(4, minmax(0, 1fr));
	gap: 12rpx;
}

.stat-card {
	min-width: 0;
	padding: 16rpx 8rpx;
	background: rgba(216, 207, 190, .25);
	border: 1rpx solid rgba(216, 207, 190, .72);
	border-radius: 8rpx;
	text-align: center;
}

.stat-card.high {
	background: rgba(194, 65, 65, .10);
	border-color: rgba(194, 65, 65, .24);
}

.stat-card.finance {
	background: rgba(166, 112, 45, .10);
	border-color: rgba(166, 112, 45, .24);
}

.stat-num {
	color: #2a2622;
	font-size: 30rpx;
	line-height: 1.2;
	font-weight: 900;
}

.stat-label {
	margin-top: 6rpx;
	color: #6b6158;
	font-size: 22rpx;
	line-height: 1.3;
}

.stat-lines {
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: 10rpx 18rpx;
	margin-top: 16rpx;
	color: #6b6158;
	font-size: 24rpx;
	line-height: 1.45;
}

.stat-lines view {
	min-width: 0;
	word-break: break-all;
}

.empty {
	height: 320rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	color: #6b6158;
	font-size: 28rpx;
}

.card {
	background: #fbf7ee;
	border: 1rpx solid #d8cfbe;
	border-radius: 10rpx;
	padding: 24rpx;
	margin-bottom: 18rpx;
	box-sizing: border-box;
	box-shadow: 0 10rpx 28rpx rgba(42, 38, 34, .05);
}

.card-head {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	gap: 18rpx;
}

.title-wrap {
	flex: 1;
	min-width: 0;
}

.title {
	color: #2a2622;
	font-size: 30rpx;
	line-height: 1.35;
	font-weight: 900;
	word-break: break-all;
}

.meta {
	margin-top: 8rpx;
	color: #6b6158;
	font-size: 24rpx;
	line-height: 1.45;
}

.risk {
	flex-shrink: 0;
	min-width: 96rpx;
	height: 44rpx;
	line-height: 44rpx;
	border-radius: 6rpx;
	text-align: center;
	font-size: 22rpx;
	font-weight: 900;
}

.risk-normal {
	background: rgba(83, 125, 150, .14);
	color: #537d96;
}

.risk-finance {
	background: rgba(166, 112, 45, .14);
	color: #8a5a1f;
}

.risk-high {
	background: rgba(194, 65, 65, .14);
	color: #a33a3a;
}

.tags {
	display: flex;
	flex-wrap: wrap;
	gap: 10rpx;
	margin-top: 18rpx;
}

.tags text {
	max-width: 100%;
	box-sizing: border-box;
	background: rgba(216, 207, 190, .32);
	border: 1rpx solid rgba(216, 207, 190, .72);
	border-radius: 6rpx;
	padding: 6rpx 12rpx;
	color: #6b6158;
	font-size: 22rpx;
	line-height: 1.35;
	word-break: break-all;
}

.content {
	margin-top: 18rpx;
	color: #303846;
	font-size: 26rpx;
	line-height: 1.65;
	white-space: pre-wrap;
	word-break: break-all;
}

.more {
	padding: 18rpx 0 8rpx;
	text-align: center;
	color: #6b6158;
	font-size: 24rpx;
}
