<view class="page">
	<view class="hero">
		<view class="hero-label">{{runtime.envText || '当前版本'}}</view>
		<view class="hero-version">v{{runtime.version || versionInfo.current}}</view>
		<view class="hero-name">{{versionInfo.name}}</view>
		<view class="hero-summary">{{versionInfo.summary}}</view>
		<view class="hero-source">{{runtime.sourceText}}</view>
	</view>

	<view class="section-title">版本更新记录</view>
	<view wx:for="{{history}}" wx:key="version" class="version-card">
		<view class="version-head">
			<view>
				<view class="version-no">v{{item.version}}</view>
				<view class="version-name">{{item.name}}</view>
			</view>
			<view class="version-side">
				<view class="status {{item.statusClass}}">{{item.statusText}}</view>
				<view class="version-date">{{item.date}}</view>
			</view>
		</view>
		<view wx:if="{{item.summary}}" class="version-summary">{{item.summary}}</view>
		<view class="version-list">
			<view wx:for="{{item.items}}" wx:for-item="line" wx:key="*this" class="version-item">
				<text>{{index + 1}}</text>
				<view>{{line}}</view>
			</view>
		</view>
	</view>
</view>

<tech-footer />
<work-pet id="workPet" />
