<view class="page" wx:if="{{data}}"><picker mode="date" fields="month" value="{{month}}" bindchange="bindMonthChange"><view class="month">{{month}}</view></picker><view class="summary"><view><text>净业绩</text><view>¥{{data.stat.netPerformance||0}}</view></view><view><text>应发</text><view>¥{{data.stat.payable||0}}</view></view><view><text>待释放</text><view>¥{{data.stat.frozenRemain||0}}</view></view></view><view class="tabs"><view data-scope="staff" bindtap="bindScopeTap">员工排行</view><view data-scope="team" bindtap="bindScopeTap">团队排行</view></view><view wx:for="{{rankList}}" wx:key="id" class="card"><view class="no">{{item.rankNo}}</view><view class="main"><view class="title">{{item.name}}</view><view class="meta">收款{{item.incomeCount||0}}笔 退款{{item.refundCount||0}}笔</view></view><view class="amount">¥{{item.netPerformance||0}}</view></view></view>

