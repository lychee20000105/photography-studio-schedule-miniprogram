page{background:#f6f7f9}.page{padding:24rpx}.month{height:84rpx;line-height:84rpx;background:#fff;border-radius:14rpx;text-align:center;font-size:34rpx;font-weight:900;margin-bottom:18rpx}.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-bottom:20rpx}.summary>view{background:#fff;border-radius:14rpx;padding:20rpx 8rpx;text-align:center}.summary text{font-size:22rpx;color:#8b9099}.summary view view{font-size:30rpx;font-weight:900;color:#111827;margin-top:8rpx}.tabs{display:flex;background:#fff;border-radius:14rpx;margin-bottom:18rpx;overflow:hidden}.tabs view{flex:1;text-align:center;padding:22rpx 0;font-weight:900;color:#ff2d62}.card{display:flex;align-items:center;background:#fff;border-radius:14rpx;padding:24rpx;margin-bottom:16rpx}.no{width:54rpx;height:54rpx;line-height:54rpx;border-radius:27rpx;background:#111827;color:#fff;text-align:center;font-weight:900}.main{flex:1;margin-left:18rpx;min-width:0}.title{font-size:30rpx;font-weight:900;color:#111827}.meta{font-size:24rpx;color:#8b9099;margin-top:8rpx}.amount{color:#ff2d62;font-size:30rpx;font-weight:900}