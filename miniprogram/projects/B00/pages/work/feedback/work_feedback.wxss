page {
	background: #f6f7f9;
}

.page {
	width: 100%;
	padding: 24rpx;
	box-sizing: border-box;
}

.card {
	background: #fff;
	border-radius: 14rpx;
	padding: 28rpx;
	box-sizing: border-box;
}

.title {
	color: #111827;
	font-size: 34rpx;
	font-weight: 900;
	line-height: 1.35;
}

.desc {
	margin-top: 12rpx;
	color: #7b8492;
	font-size: 26rpx;
	line-height: 1.55;
}

.textarea {
	width: 100%;
	min-height: 320rpx;
	margin-top: 24rpx;
	padding: 22rpx;
	background: #f7f8fa;
	border-radius: 12rpx;
	box-sizing: border-box;
	color: #1f2937;
	font-size: 28rpx;
	line-height: 1.55;
}

.count {
	margin-top: 12rpx;
	text-align: right;
	color: #9aa1ad;
	font-size: 24rpx;
}

.submit {
	margin-top: 28rpx;
	height: 84rpx;
	line-height: 84rpx;
	border-radius: 12rpx;
	background: #ff2d62;
	color: #fff;
	font-size: 30rpx;
	font-weight: 900;
}
