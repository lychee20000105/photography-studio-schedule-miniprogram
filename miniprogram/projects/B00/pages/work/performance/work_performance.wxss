page { background: #f6f7f9; }
.page { padding: 24rpx 24rpx 48rpx; box-sizing: border-box; }
.guest-banner { margin-bottom: 18rpx; padding: 20rpx 22rpx; border-radius: 14rpx; background: #111827; color: #fff; font-size: 25rpx; line-height: 1.45; }
.month-card { height: 88rpx; border-radius: 16rpx; background: #fff; display: flex; align-items: center; justify-content: space-between; padding: 0 28rpx; box-sizing: border-box; font-size: 34rpx; font-weight: 900; margin-bottom: 22rpx; }
.month-tip { font-size: 24rpx; color: #8b9099; font-weight: 500; }
.block-title { margin: 28rpx 0 16rpx; color: #111827; font-size: 34rpx; font-weight: 900; }
.order-block-title { margin-top: 42rpx; }
.hero { background: linear-gradient(135deg, #111827, #ff2d62); color: #fff; border-radius: 20rpx; padding: 34rpx 30rpx; margin-bottom: 20rpx; box-shadow: 0 12rpx 30rpx rgba(255,45,98,.18); }
.hero-label { font-size: 26rpx; opacity: .86; }
.hero-money { font-size: 58rpx; font-weight: 900; margin-top: 12rpx; line-height: 1.1; }
.hero-sub { margin-top: 14rpx; font-size: 24rpx; opacity: .88; }
.order-entry { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; margin-bottom: 20rpx; padding: 24rpx; border-radius: 14rpx; background: #fff; box-sizing: border-box; }
.order-entry-title { color: #111827; font-size: 30rpx; font-weight: 900; line-height: 1.35; }
.order-entry-sub { margin-top: 8rpx; color: #8b9099; font-size: 24rpx; line-height: 1.45; }
.order-entry-btn { flex: none; height: 60rpx; line-height: 60rpx; padding: 0 26rpx; border-radius: 30rpx; background: #111827; color: #fff; font-size: 24rpx; font-weight: 900; }
.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; margin-bottom: 28rpx; }
.metric { background: #fff; border-radius: 14rpx; padding: 22rpx 10rpx; text-align: center; box-sizing: border-box; }
.metric text { color: #8b9099; font-size: 22rpx; }
.metric view { color: #111827; font-size: 30rpx; font-weight: 900; margin-top: 10rpx; }
.danger { color: #dc2626 !important; }
.section-head { display: flex; align-items: center; justify-content: space-between; margin: 34rpx 0 16rpx; font-size: 34rpx; font-weight: 900; color: #111827; }
.rank-head { gap: 18rpx; }
.rank-head-actions { flex: none; display: flex; align-items: center; gap: 12rpx; }
.rank-toggle { height: 50rpx; line-height: 50rpx; padding: 0 18rpx; border-radius: 25rpx; background: #fff; color: #111827; border: 1rpx solid #d8dee8; font-size: 23rpx; font-weight: 800; }
.rank-toggle.active { background: #111827; color: #fff; border-color: #111827; }
.rank-collapsed { background: #fff; border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; box-sizing: border-box; color: #8b9099; font-size: 25rpx; text-align: center; }
.own-rank-card { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; background: #fff; border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.own-rank-title { color: #111827; font-size: 29rpx; font-weight: 900; }
.own-rank-meta { margin-top: 8rpx; color: #8b9099; font-size: 23rpx; line-height: 1.45; }
.own-rank-money { flex: none; color: #ff2d62; font-size: 31rpx; font-weight: 900; }
.seg { display: flex; padding: 6rpx; background: #eceff3; border-radius: 28rpx; }
.seg-item { height: 44rpx; line-height: 44rpx; padding: 0 20rpx; border-radius: 22rpx; color: #6b7280; font-size: 23rpx; font-weight: 700; }
.seg-item.active { background: #ff2d62; color: #fff; }
.rank-card, .list-card, .empty-card { background: #fff; border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.rank-card { display: flex; align-items: center; }
.rank-no { flex: none; width: 54rpx; height: 54rpx; line-height: 54rpx; border-radius: 27rpx; background: #111827; color: #fff; font-size: 26rpx; font-weight: 900; text-align: center; }
.rank-main { flex: 1; min-width: 0; margin-left: 18rpx; }
.rank-name { font-size: 30rpx; font-weight: 900; color: #111827; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.rank-meta, .list-meta, .empty-desc { color: #8b9099; font-size: 24rpx; margin-top: 8rpx; }
.rank-money { color: #ff2d62; font-size: 30rpx; font-weight: 900; margin-left: 16rpx; }
.rank-hidden { color: #9ca3af; font-size: 24rpx; font-weight: 700; margin-left: 16rpx; }
.list-card { position: relative; padding-right: 170rpx; }
.list-title { font-size: 29rpx; font-weight: 900; color: #111827; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.list-money { position: absolute; right: 24rpx; top: 28rpx; color: #ff2d62; font-size: 30rpx; font-weight: 900; }
.order-summary-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; margin-bottom: 20rpx; }
.order-summary-item { background: #fff; border-radius: 14rpx; padding: 22rpx 18rpx; box-sizing: border-box; text-align: center; }
.order-summary-item view { color: #111827; font-size: 34rpx; font-weight: 900; line-height: 1.2; }
.order-summary-item text { display: block; margin-top: 8rpx; color: #8b9099; font-size: 23rpx; }
.order-list-head { margin-top: 24rpx; }
.more-link { height: 50rpx; line-height: 50rpx; padding: 0 18rpx; border-radius: 25rpx; background: #fff; color: #111827; border: 1rpx solid #d8dee8; font-size: 23rpx; font-weight: 800; }
.order-card { background: #fff; border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.order-card-top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.order-customer { flex: 1; min-width: 0; color: #111827; font-size: 30rpx; font-weight: 900; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.order-status { flex: none; color: #3f6179; background: rgba(83,125,150,.12); border-radius: 999rpx; padding: 8rpx 14rpx; font-size: 22rpx; font-weight: 800; }
.order-card-line { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; margin-top: 14rpx; color: #6b7280; font-size: 24rpx; }
.order-type { color: #fff; border-radius: 6rpx; padding: 5rpx 10rpx; font-size: 22rpx; font-weight: 800; }
.order-card-money { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin-top: 16rpx; padding: 14rpx 12rpx; border-radius: 10rpx; background: #f6f7f9; color: #111827; font-size: 23rpx; font-weight: 800; text-align: center; }
.order-card-settle { margin-top: 14rpx; color: #8b9099; font-size: 23rpx; line-height: 1.45; }
.empty { padding: 40rpx 24rpx; text-align: center; color: #8b9099; }
.empty.small { background: #fff; border-radius: 14rpx; margin-bottom: 16rpx; padding: 30rpx 24rpx; }
.empty-title { font-size: 32rpx; color: #111827; font-weight: 900; text-align: center; }
.empty-desc { text-align: center; }

/* Warm paper overrides */
page { background: #f5efe4; background-image: linear-gradient(90deg, rgba(122,96,68,.035) 1rpx, transparent 1rpx), linear-gradient(180deg, rgba(255,253,247,.56), rgba(216,207,190,.22)); background-size: 48rpx 48rpx, 100% 100%; color: #2a2622; }
.page { padding-bottom: 138rpx; }
.guest-banner, .month-card, .metric, .order-entry, .rank-card, .rank-collapsed, .own-rank-card, .list-card, .order-summary-item, .order-card, .empty-card, .empty.small { background: #fbf7ee; border: 1rpx solid #d8cfbe; box-shadow: 0 12rpx 38rpx rgba(42,38,34,.06); }
.guest-banner { color: #2a2622; }
.month-card, .hero, .rank-card, .own-rank-card, .list-card, .order-summary-item, .order-card, .empty-card, .empty.small { border-radius: 10rpx; }
.month-card, .block-title, .section-head, .order-entry-title, .rank-name, .own-rank-title, .list-title, .order-customer, .empty-title { color: #2a2622; }
.month-tip, .metric text, .order-entry-sub, .rank-meta, .own-rank-meta, .list-meta, .order-card-line, .order-card-settle, .empty-desc, .empty { color: #6b6158; }
.hero { background: #fbf7ee; color: #2a2622; border: 1rpx solid #d8cfbe; box-shadow: 0 16rpx 42rpx rgba(42,38,34,.07); position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 8rpx; background: #537d96; }
.hero-label, .hero-sub { color: #6b6158; opacity: 1; }
.hero-money, .metric view { color: #2a2622; }
.grid { gap: 12rpx; }
.metric { border-radius: 8rpx; }
.seg { background: rgba(216,207,190,.48); border: 1rpx solid rgba(216,207,190,.78); border-radius: 8rpx; }
.seg-item { color: #6b6158; border-radius: 6rpx; }
.seg-item.active, .rank-no { background: #537d96; color: #fff; }
.order-entry-btn { background: #537d96; }
.rank-toggle { background: #fbf7ee; color: #3f6179; border-color: #d8cfbe; border-radius: 8rpx; }
.rank-toggle.active { background: #537d96; color: #fff; border-color: #537d96; }
.rank-money, .own-rank-money, .list-money { color: #537d96; }
.more-link { background: #fbf7ee; color: #3f6179; border-color: #d8cfbe; border-radius: 8rpx; }
.order-summary-item view { color: #2a2622; }
.order-summary-item text { color: #6b6158; }
.order-status { color: #3f6179; background: rgba(83,125,150,.12); }
.order-card-money { background: rgba(216,207,190,.26); color: #2a2622; }
.danger { color: #8b2c1f !important; }
