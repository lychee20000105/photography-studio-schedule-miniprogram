page{background:#f6f7f9}.page{padding:24rpx}.month{height:84rpx;line-height:84rpx;background:#fff;border-radius:14rpx;text-align:center;font-size:32rpx;font-weight:900;margin-bottom:20rpx}.hero{background:linear-gradient(135deg,#111827,#ff2d62);color:#fff;border-radius:18rpx;padding:32rpx 28rpx;margin-bottom:18rpx}.label{font-size:24rpx;opacity:.85}.money{font-size:56rpx;font-weight:900;margin-top:8rpx}.sub{font-size:24rpx;opacity:.85;margin-top:10rpx}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-bottom:22rpx}.metric{background:#fff;border-radius:14rpx;padding:20rpx 8rpx;text-align:center}.metric text{font-size:22rpx;color:#8b9099}.metric view{font-size:30rpx;font-weight:900;margin-top:8rpx;color:#111827}.menu{background:#fff;border-radius:14rpx;padding:0 24rpx}.item{min-height:104rpx;display:flex;align-items:center;justify-content:space-between;border-bottom:1rpx solid #edf0f4}.item:last-child{border-bottom:0}.title{font-size:30rpx;font-weight:900;color:#111827}.desc{font-size:24rpx;color:#8b9099;margin-top:8rpx}.arrow{font-size:42rpx;color:#b5bbc5}.empty{text-align:center;color:#8b9099;padding:80rpx 0}
