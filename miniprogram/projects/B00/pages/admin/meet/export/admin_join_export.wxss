page {
	background: #f6f7f9;
}

.page {
	padding: 24rpx;
}

.title {
	font-size: 34rpx;
	font-weight: 900;
	color: #111827;
	margin-bottom: 18rpx;
}

.form,
.file {
	background: #fff;
	border-radius: 14rpx;
	padding: 8rpx 24rpx;
	margin-bottom: 22rpx;
}

.row {
	min-height: 92rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	border-bottom: 1rpx solid #edf0f4;
}

.row:last-child {
	border-bottom: 0;
}

.row text {
	color: #6b7280;
	font-size: 28rpx;
}

.picker {
	font-weight: 900;
	color: #111827;
}

.btn-primary,
.btn {
	border-radius: 12rpx;
	margin: 18rpx 0;
}

.btn-primary {
	background: #2499f2;
	color: #fff;
}

.btn {
	background: #fff;
	color: #2499f2;
}

.danger {
	color: #dc2626;
}

.muted {
	color: #6b7280;
}

.file-title {
	font-size: 30rpx;
	font-weight: 900;
	color: #111827;
	margin-top: 18rpx;
}

.file-time,
.empty {
	font-size: 26rpx;
	color: #8b9099;
	padding: 18rpx 0;
}
