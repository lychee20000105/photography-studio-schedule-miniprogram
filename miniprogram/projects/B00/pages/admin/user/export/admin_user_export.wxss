page {
	background: #f6f7f9;
}

.page {
	padding: 24rpx;
}

.title {
	font-size: 34rpx;
	font-weight: 900;
	color: #111827;
	margin-bottom: 12rpx;
}

.hint,
.file-time,
.empty {
	font-size: 26rpx;
	color: #8b9099;
	margin-bottom: 22rpx;
}

.file {
	background: #fff;
	border-radius: 14rpx;
	padding: 24rpx;
	margin-bottom: 22rpx;
}

.file-title {
	font-size: 30rpx;
	font-weight: 900;
	color: #111827;
	margin-bottom: 12rpx;
}

.btn-primary,
.btn {
	border-radius: 12rpx;
	margin: 18rpx 0;
}

.btn-primary {
	background: #2499f2;
	color: #fff;
}

.btn {
	background: #fff;
	color: #2499f2;
}

.danger {
	color: #dc2626;
}

.muted {
	color: #6b7280;
}
